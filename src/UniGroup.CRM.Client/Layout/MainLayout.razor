@inherits LayoutComponentBase
@implements IDisposable
@inject JwtAuthenticationStateProvider Auth
@inject ThemeService Theme
@inject LanguageService Lang
@inject NavigationManager Nav
@inject CrmApiClient Api
@inject EmbeddedStateService Embedded
@inject ChatwootContextService CwContext

<div class="app-shell @(Embedded.IsEmbedded ? "embedded" : "")">
    <AuthorizeView>
        <Authorized>
            @if (Embedded.IsEmbedded)
            {
                <!-- ══════════ EMBEDDED (Chatwoot Dashboard App) CHROME ══════════ -->
                <div class="main-area embedded-main">
                    <header class="embed-topbar">
                        <div class="embed-tabs">
                            <AuthorizeView Roles="Admin,Team Leader,TeamLeader" Context="edash">
                                <NavLink class="embed-tab" href="/" Match="NavLinkMatch.All" title="@T("Nav.Dashboard")"><i class="bi bi-speedometer2"></i><span>@T("Nav.Dashboard")</span></NavLink>
                            </AuthorizeView>
                            <NavLink class="embed-tab" href="/customers" title="@T("Nav.Customers")"><i class="bi bi-person-badge"></i><span>@T("Cust.Title")</span></NavLink>
                            <NavLink class="embed-tab" href="/tickets/new" title="@T("TkC.Title")"><i class="bi bi-ticket-perforated"></i><span>@T("TkC.Title")</span></NavLink>
                            <NavLink class="embed-tab" href="/my-tickets" title="@T("Nav.MyTickets")"><i class="bi bi-clipboard-check"></i><span>@T("Nav.MyTickets")</span></NavLink>
                            <NavLink class="embed-tab" href="/knowledge-base" title="@T("Nav.KnowledgeBase")"><i class="bi bi-book"></i><span>@T("Nav.KnowledgeBase")</span></NavLink>
                        </div>
                        <div style="flex:1"></div>
                        @if (CwContext.HasContext)
                        {
                            <span class="embed-ctx-badge" title="@T("Cw.ActiveConversation")">
                                <i class="bi bi-chat-left-dots"></i>
                                @(string.IsNullOrEmpty(CwContext.ContactName) ? (CwContext.ContactPhone ?? "#" + CwContext.ConversationId) : CwContext.ContactName)
                            </span>
                        }
                        <button class="embed-icon-btn" title="@T("Nav.ToggleLanguage")" @onclick="ToggleLanguageAsync">
                            <i class="bi bi-translate"></i>
                        </button>
                        <button class="embed-icon-btn" title="@T("Nav.ToggleTheme")" @onclick="ToggleThemeAsync">
                            <i class="bi @(Theme.Current == "dark" ? "bi-moon" : "bi-sun")"></i>
                        </button>
                    </header>
                    <main class="embed-body">
                        @Body
                    </main>
                </div>
            }
            else
            {
            <aside class="sidebar @(_sidebarOpen ? "open" : "")">
                <div class="sidebar-logo">
                    <div class="mark">U</div>
                    <div>
                        <div class="name">UniGroup <span>CRM</span></div>
                        <div class="tag">@T("Nav.Tagline")</div>
                    </div>
                </div>

                <nav class="nav-group">
                    <div class="nav-group-label">@T("Nav.Workspace")</div>
                    <AuthorizeView Roles="Admin,Team Leader,TeamLeader" Context="dash">
                        <NavLink class="nav-item" href="/" Match="NavLinkMatch.All"><span class="ico"><i class="bi bi-speedometer2"></i></span> @T("Nav.Dashboard")</NavLink>
                    </AuthorizeView>
                    <NavLink class="nav-item" href="/customers"><span class="ico"><i class="bi bi-people"></i></span> @T("Nav.Customers")</NavLink>
                    <NavLink class="nav-item" href="/tickets"><span class="ico"><i class="bi bi-ticket-perforated"></i></span> @T("Nav.Tickets")</NavLink>
                    <NavLink class="nav-item" href="/my-tickets"><span class="ico"><i class="bi bi-clipboard-check"></i></span> @T("Nav.MyTickets")</NavLink>
                    <NavLink class="nav-item" href="/knowledge-base"><span class="ico"><i class="bi bi-book"></i></span> @T("Nav.KnowledgeBase")</NavLink>
                </nav>

                <AuthorizeView Roles="Admin,Team Leader,TeamLeader" Context="mgmt">
                    <nav class="nav-group">
                        <div class="nav-group-label">@T("Nav.Management")</div>
                        <NavLink class="nav-item" href="/csat-report"><span class="ico"><i class="bi bi-star"></i></span> @T("Nav.CsatReport")</NavLink>
                        <AuthorizeView Roles="Admin" Context="adminOnly">
                            <NavLink class="nav-item" href="/reports"><span class="ico"><i class="bi bi-file-earmark-spreadsheet"></i></span> @T("Nav.Reports")</NavLink>
                        </AuthorizeView>
                    </nav>
                </AuthorizeView>

                <div class="sidebar-footer">
                    <div class="row" style="margin-bottom:10px">
                        <div class="avatar">@UiHelpers.Initials(Auth.Session?.FullName)</div>
                        <div style="min-width:0">
                            <div style="font-weight:600;font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@Auth.Session?.FullName</div>
                            <div class="subtle" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@RoleLabel</div>
                        </div>
                    </div>
                    <button class="btn btn-secondary btn-sm" style="width:100%" @onclick="SignOutAsync">
                        <i class="bi bi-box-arrow-left"></i> @T("Nav.SignOut")
                    </button>
                </div>
            </aside>

            @if (_sidebarOpen)
            {
                <div style="position:fixed;inset:0;z-index:99;background:rgba(5,8,20,0.4)" @onclick="() => _sidebarOpen = false"></div>
            }

            <div class="main-area">
                <header class="topbar">
                    <button class="menu-btn" @onclick="() => _sidebarOpen = !_sidebarOpen"><i class="bi bi-list"></i></button>

                    <div class="search-box">
                        <span class="ico"><i class="bi bi-search"></i></span>
                        <input class="input" placeholder="@T("Nav.SearchPlaceholder")"
                               value="@_searchTerm"
                               @oninput="OnSearchInput"
                               @onfocusout="CloseSearchSoon" />
                        @if (_searchOpen)
                        {
                            <div class="glass search-results anim-fade-up">
                                @if (_searching)
                                {
                                    <div style="padding:14px" class="row"><span class="spinner dark"></span><span class="muted">@T("Nav.Searching")</span></div>
                                }
                                else if (_searchResults.Count == 0)
                                {
                                    <div class="empty-state" style="padding:22px"><div>@T("Nav.NoMatches")</div></div>
                                }
                                else
                                {
                                    @foreach (var c in _searchResults)
                                    {
                                        <div class="search-result-item" @onmousedown="() => GoToCustomer(c.Id)">
                                            <div class="avatar">@UiHelpers.Initials(c.Name)</div>
                                            <div style="min-width:0">
                                                <div style="font-weight:600;font-size:13px">@c.Name</div>
                                                <div class="subtle">@(c.Phones.FirstOrDefault(p => p.IsPrimary)?.Phone ?? c.Phones.FirstOrDefault()?.Phone) · @T("Common.DevicesCount", c.Devices.Count)</div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>

                    <div style="flex:1"></div>

                    <button class="lang-toggle" title="@T("Nav.ToggleLanguage")" @onclick="ToggleLanguageAsync">
                        <i class="bi bi-translate"></i>
                        <span>@(Lang.Current == "ar" ? "EN" : "عربي")</span>
                    </button>

                    <button class="theme-toggle" title="@T("Nav.ToggleTheme")" @onclick="ToggleThemeAsync">
                        <i class="bi @(Theme.Current == "dark" ? "bi-moon" : "bi-sun")"></i>
                    </button>
                </header>

                <main style="flex:1">
                    @Body
                </main>
            </div>

            <CallerIdWidget />
            }
        </Authorized>
        <NotAuthorized>
            <div style="flex:1">@Body</div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<ToastHost />

@code {
    private bool _sidebarOpen;
    private string _searchTerm = string.Empty;
    private bool _searchOpen;
    private bool _searching;
    private List<CustomerDetailsDto> _searchResults = [];
    private CancellationTokenSource? _searchCts;

    private string T(string key) => TranslationResources.Get(key, Lang.Current);
    private string T(string key, params object?[] args) => string.Format(TranslationResources.Get(key, Lang.Current), args);

    private string RoleLabel => Auth.Session is { Roles.Count: > 0 } s ? string.Join(" · ", s.Roles) : T("Nav.User");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Theme.InitializeAsync();
            await Lang.InitializeAsync();
            // When embedded in Chatwoot, wire up the live conversation bridge so
            // every CRM page can react to the active customer.
            if (Embedded.IsEmbedded)
            {
                await CwContext.EnsureRegisteredAsync();
            }
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        // Detect ?embedded=true once and cache it for the whole SPA session.
        Embedded.Initialize(Nav);

        Theme.OnChange += StateHasChanged;
        Lang.OnChange += StateHasChanged;
        Embedded.OnChange += OnEmbeddedChanged;
        CwContext.OnContextChanged += OnContextChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnEmbeddedChanged() => InvokeAsync(StateHasChanged);

    private void OnContextChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _sidebarOpen = false;
        _searchOpen = false;
        StateHasChanged();
    }

    private async Task ToggleThemeAsync() => await Theme.ToggleAsync();

    private async Task ToggleLanguageAsync() => await Lang.ToggleAsync();

    private async Task SignOutAsync()
    {
        await Auth.SignOutAsync();
        Nav.NavigateTo("/login");
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
        _searchCts?.Cancel();

        if (_searchTerm.Trim().Length < 2)
        {
            _searchOpen = false;
            return;
        }

        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;
        _searchOpen = true;
        _searching = true;

        try
        {
            await Task.Delay(350, token); // debounce
            var results = await Api.SystemSearchAsync(_searchTerm.Trim());
            if (!token.IsCancellationRequested)
            {
                _searchResults = results.Take(8).ToList();
            }
        }
        catch (OperationCanceledException) { }
        catch { _searchResults = []; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _searching = false;
                StateHasChanged();
            }
        }
    }

    private async Task CloseSearchSoon()
    {
        await Task.Delay(180);
        _searchOpen = false;
    }

    private void GoToCustomer(Guid id)
    {
        _searchOpen = false;
        _searchTerm = string.Empty;
        Nav.NavigateTo($"/customers/{id}");
    }

    public void Dispose()
    {
        Theme.OnChange -= StateHasChanged;
        Lang.OnChange -= StateHasChanged;
        Embedded.OnChange -= OnEmbeddedChanged;
        CwContext.OnContextChanged -= OnContextChanged;
        Nav.LocationChanged -= OnLocationChanged;
        _searchCts?.Cancel();
    }
}
