@page "/tickets/new"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts
@inject EmbeddedStateService Embedded
@inject ChatwootContextService CwContext

<PageTitle>@T("TkC.PageTitle")</PageTitle>

<div class="page-pad anim-fade-up">
    @if (Embedded.IsEmbedded && !string.IsNullOrEmpty(_conversationId))
    {
        <div class="cw-context-banner">
            <i class="bi bi-link-45deg"></i>
            <div style="flex:1;min-width:0">
                <strong>@T("Cw.LinkedToConversation")</strong>
                <span class="subtle"> #@_conversationId</span>
            </div>
        </div>
    }

    <div class="spread" style="margin-bottom:20px">
        <div>
            <h1 style="font-size:22px">@T("TkC.Title")</h1>
            <p class="muted" style="margin:4px 0 0">@T("TkC.Subtitle")</p>
        </div>
        <button class="btn btn-ghost" @onclick="GoBack"><i class="bi bi-arrow-left flip-rtl"></i> @T("TkC.Back")</button>
    </div>

    <div class="grid" style="grid-template-columns:minmax(0,1.15fr) minmax(0,0.85fr);align-items:start;gap:20px">

        <!-- ══════════════ FORM COLUMN ══════════════ -->
        <div class="card glass" style="padding:24px">

            <!-- Customer picker -->
            <div class="field">
                <label>@T("TkC.Customer") *</label>
                @if (_customer is null)
                {
                    <input class="input" placeholder="@T("TkC.CustomerSearchPlaceholder")"
                           value="@_customerSearch" @oninput="OnCustomerSearchInput" />
                    @if (_searching)
                    {
                        <div class="card" style="padding:12px 14px;margin-top:6px"><span class="subtle">@T("Nav.Searching")</span></div>
                    }
                    else if (_customerResults is { Count: > 0 })
                    {
                        <div class="card" style="padding:6px;margin-top:6px;max-height:260px;overflow:auto">
                            @foreach (var c in _customerResults)
                            {
                                var cust = c;
                                <button type="button" class="search-result-item" style="width:100%;text-align:start"
                                        @onclick="() => SelectCustomer(cust)">
                                    <div class="row">
                                        <div class="avatar">@UiHelpers.Initials(cust.Name)</div>
                                        <div style="min-width:0;flex:1">
                                            <div style="font-weight:700;font-size:13.5px">@cust.Name</div>
                                            <div class="subtle">@(PrimaryPhone(cust) ?? "—") · @(cust.Email ?? T("Common.NoEmail"))</div>
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                    else if (_searchedOnce && _customerSearch.Trim().Length >= 2)
                    {
                        <div class="card" style="padding:12px 14px;margin-top:6px"><span class="subtle">@T("TkC.NoCustomers", _customerSearch)</span></div>
                    }
                }
                else
                {
                    <div class="card" style="padding:12px 14px">
                        <div class="row spread">
                            <div class="row">
                                <div class="avatar">@UiHelpers.Initials(_customer.Name)</div>
                                <div>
                                    <div style="font-weight:700;font-size:13.5px">@_customer.Name</div>
                                    <div class="subtle mono">@(PrimaryPhone(_customer) ?? "—")</div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-ghost btn-sm" @onclick="ClearCustomer">@T("Common.Change")</button>
                        </div>
                    </div>
                }
            </div>

            <!-- Device picker -->
            <div class="field">
                <label>@T("TkC.Device")</label>
                @if (_customer is null)
                {
                    <div class="subtle">@T("TkC.SelectCustomerFirst")</div>
                }
                else if (_customer.Devices.Count == 0)
                {
                    <div class="subtle">@T("TkC.NoRegisteredDevices")</div>
                }
                else
                {
                    <select class="select" @onchange="OnDeviceChanged">
                        <option value="">@T("TkC.NoSpecificDevice")</option>
                        @foreach (var d in _customer.Devices)
                        {
                            <option value="@d.Id" selected="@(_deviceId == d.Id)">@d.BrandName @d.ModelName@(string.IsNullOrEmpty(d.IMEI) ? "" : $" · IMEI {d.IMEI}")</option>
                        }
                    </select>
                    @if (SelectedDevice is { } dev)
                    {
                        <div class="row" style="gap:8px;margin-top:4px">
                            <span class="badge @UiHelpers.WarrantyBadge(dev.WarrantyStatus)"><i class="bi bi-shield-check"></i> @T("TkC.WarrantyLabel", TWarranty(dev.WarrantyStatus))</span>
                            <span class="subtle">@T("TkC.WarrantyExpires", dev.WarrantyExpiry.ToString("dd MMM yyyy"))</span>
                        </div>
                    }
                }
            </div>

            <!-- Main Category + Sub Category -->
            <div class="row" style="gap:14px;align-items:flex-start">
                <div class="field" style="flex:1">
                    <label>@T("TkC.MainCategory") *</label>
                    <select class="select" @onchange="OnMainCategoryChanged">
                        @foreach (var mc in Enum.GetValues<MainCategory>())
                        {
                            <option value="@((int)mc)" selected="@(_mainCategory == mc)">@TMainCategory(mc.ToString())</option>
                        }
                    </select>
                </div>
                <div class="field" style="flex:1">
                    <label>@T("TkC.SubCategory") *</label>
                    <select class="select" @onchange="OnCategoryChanged">
                        @foreach (var cat in TicketCategoryMap.GetSubCategories(_mainCategory))
                        {
                            <option value="@((int)cat)" selected="@(_category == cat)">@TCategory(cat.ToString())</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Priority -->
            <div class="row" style="gap:14px;align-items:flex-start">
                <div class="field" style="flex:1">
                    <label>@T("TkC.Priority") *</label>
                    <select class="select" @onchange="OnPriorityChanged">
                        @foreach (var pr in Enum.GetValues<TicketPriority>())
                        {
                            <option value="@((int)pr)" selected="@(_priority == pr)">@TPriority(pr.ToString()) — @T("TkC.SlaSuffix", UiHelpers.SlaHours[pr])</option>
                        }
                    </select>
                </div>
            </div>

            <div class="field">
                <label>@T("TkC.TitleField") *</label>
                <input class="input" maxlength="200" placeholder="@T("TkC.TitlePlaceholder")"
                       @bind="_title" @bind:event="oninput" />
            </div>

            <div class="field">
                <label>@T("TkC.Description") *</label>
                <textarea class="textarea" rows="6" placeholder="@T("TkC.DescriptionPlaceholder")"
                          @bind="_description" @bind:event="oninput"></textarea>
            </div>

            @if (_error is not null)
            {
                <div class="badge badge-red" style="display:block;padding:10px 14px;margin-bottom:14px;white-space:normal"><i class="bi bi-exclamation-triangle"></i> @_error</div>
            }

            <div class="row" style="justify-content:flex-end;gap:10px">
                <button class="btn btn-ghost" @onclick="GoBack" disabled="@_submitting">@T("Common.Cancel")</button>
                <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(!CanSubmit || _submitting)">
                    @if (_submitting)
                    {
                        @T("TkC.Creating")
                    }
                    else
                    {
                        <i class="bi bi-ticket-perforated"></i> @T("TkC.CreateBtn")
                    }
                </button>
            </div>
        </div>

        <!-- ══════════════ KB GUIDANCE COLUMN ══════════════ -->
        <div style="position:sticky;top:16px">
            <div class="section-title" style="margin-bottom:10px"><i class="bi bi-journal-bookmark"></i> @T("TkC.Guidance", TCategory(_category.ToString()))</div>
            @if (_loadingArticle)
            {
                <div class="grid" style="gap:12px">
                    <Skeleton Height="90px" /><Skeleton Height="90px" /><Skeleton Height="90px" />
                </div>
            }
            else if (_article is null)
            {
                <div class="card empty-state" style="padding:28px">
                    <div class="icon"><i class="bi bi-file-earmark-text"></i></div>
                    <h3>@T("TkC.NoGuidanceTitle")</h3>
                    <p>@T("TkC.NoGuidanceText") <b>@TCategory(_category.ToString())</b></p>
                </div>
            }
            else
            {
                <div class="grid" style="gap:12px">
                    <div style="font-weight:800;font-size:15px">@_article.Title</div>
                    <div class="card kb-section-card questions">
                        <div style="font-weight:700;font-size:13px;margin-bottom:8px"><i class="bi bi-question-circle"></i> @T("Kb.Questions")</div>
                        <MarkdownView Content="@_article.QuestionsToAsk" />
                    </div>
                    <div class="card kb-section-card diagnosis">
                        <div style="font-weight:700;font-size:13px;margin-bottom:8px"><i class="bi bi-search"></i> @T("Kb.Diagnosis")</div>
                        <MarkdownView Content="@_article.DiagnosisSteps" />
                    </div>
                    <div class="card kb-section-card answers">
                        <div style="font-weight:700;font-size:13px;margin-bottom:8px"><i class="bi bi-chat-dots"></i> @T("Kb.Answers")</div>
                        <MarkdownView Content="@_article.SuggestedAnswers" />
                    </div>
                    <div class="card kb-section-card escalation">
                        <div style="font-weight:700;font-size:13px;margin-bottom:8px"><i class="bi bi-exclamation-octagon"></i> @T("Kb.Escalation")</div>
                        <MarkdownView Content="@_article.EscalationConditions" />
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    /// <summary>Optional pre-selected customer, e.g. /tickets/new?customerId=…</summary>
    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerId { get; set; }

    /// <summary>
    /// Optional Chatwoot conversation to link the new ticket to, e.g.
    /// /tickets/new?customerId=…&amp;conversationId=42. When present (embedded
    /// mode), submitting links the ticket to the conversation so future Chatwoot
    /// messages append to it as internal notes.
    /// </summary>
    [SupplyParameterFromQuery(Name = "conversationId")]
    public string? ConversationIdParam { get; set; }

    private string? _conversationId;

    private string _customerSearch = string.Empty;
    private List<CustomerDetailsDto>? _customerResults;
    private CustomerDetailsDto? _customer;
    private bool _searching;
    private bool _searchedOnce;
    private System.Threading.Timer? _debounce;

    private Guid? _deviceId;
    private MainCategory _mainCategory = MainCategory.GeneralSupport;
    private TicketCategory _category = TicketCategory.GeneralInquiry;
    private TicketPriority _priority = TicketPriority.Medium;
    private string _title = string.Empty;
    private string _description = string.Empty;

    private KnowledgeBaseArticleDto? _article;
    private bool _loadingArticle;

    private bool _submitting;
    private string? _error;

    private CustomerDeviceDto? SelectedDevice => _customer?.Devices.FirstOrDefault(d => d.Id == _deviceId);

    private bool CanSubmit =>
        _customer is not null &&
        !string.IsNullOrWhiteSpace(_title) &&
        !string.IsNullOrWhiteSpace(_description);

    private static string? PrimaryPhone(CustomerDetailsDto c) =>
        c.Phones.FirstOrDefault(p => p.IsPrimary)?.Phone ?? c.Phones.FirstOrDefault()?.Phone;

    protected override void OnInitialized()
    {
        base.OnInitialized(); // keep language-change subscription from the base
        if (Embedded.IsEmbedded)
        {
            CwContext.OnContextChanged += OnCwContextChanged;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Resolve the Chatwoot conversation to link: query param wins, else the
        // live embedded context.
        _conversationId = !string.IsNullOrWhiteSpace(ConversationIdParam)
            ? ConversationIdParam
            : (Embedded.IsEmbedded ? CwContext.ConversationId : null);

        // Pre-select the customer from the query param, otherwise auto-match the
        // active Chatwoot contact by phone/email so the agent starts ready-to-go.
        if (CustomerId is Guid cid)
        {
            try { _customer = await Api.GetCustomerAsync(cid); }
            catch { /* ignore bad query param */ }
        }
        else if (Embedded.IsEmbedded && CwContext.HasContext)
        {
            await TryMatchCustomerFromContextAsync();
        }

        await LoadArticleAsync();
    }

    private void OnCwContextChanged() => InvokeAsync(async () =>
    {
        // Keep the linked conversation current if the agent switches chats and
        // no explicit conversation was passed via the query string.
        if (string.IsNullOrWhiteSpace(ConversationIdParam))
        {
            _conversationId = CwContext.ConversationId;
        }
        if (_customer is null && CwContext.HasContext)
        {
            await TryMatchCustomerFromContextAsync();
        }
        StateHasChanged();
    });

    private async Task TryMatchCustomerFromContextAsync()
    {
        var term = !string.IsNullOrWhiteSpace(CwContext.ContactPhone)
            ? CwContext.ContactPhone
            : CwContext.ContactEmail;
        if (string.IsNullOrWhiteSpace(term)) return;
        try
        {
            var result = await Api.SearchCustomersAsync(term.Trim(), 1, 9);
            var matches = result.Customers;
            if (matches.Count > 0) _customer = matches[0];
        }
        catch { /* best-effort auto-match */ }
    }

    // ───── customer search (350 ms debounce) ─────
    private void OnCustomerSearchInput(ChangeEventArgs e)
    {
        _customerSearch = e.Value?.ToString() ?? string.Empty;
        _debounce?.Dispose();
        if (_customerSearch.Trim().Length < 2)
        {
            _customerResults = null;
            _searchedOnce = false;
            return;
        }
        _debounce = new System.Threading.Timer(_ => InvokeAsync(RunSearchAsync), null, 350, Timeout.Infinite);
    }

    private async Task RunSearchAsync()
    {
        var term = _customerSearch.Trim();
        if (term.Length < 2) return;
        _searching = true;
        StateHasChanged();
        try
        {
            var result = await Api.SearchCustomersAsync(term, 1, 9);
            _customerResults = result.Customers;
            _searchedOnce = true;
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _searching = false; StateHasChanged(); }
    }

    private void SelectCustomer(CustomerDetailsDto c)
    {
        _customer = c;
        _customerResults = null;
        _customerSearch = string.Empty;
        _deviceId = null;
    }

    private void ClearCustomer()
    {
        _customer = null;
        _deviceId = null;
    }

    private void OnDeviceChanged(ChangeEventArgs e) =>
        _deviceId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null;

    // ───── main category → cascades the sub-category list ─────
    private async Task OnMainCategoryChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _mainCategory = (MainCategory)v;

            // Reset the sub-category to the first valid option under the new main
            // category so the pairing is always consistent before submit.
            var subs = TicketCategoryMap.GetSubCategories(_mainCategory);
            if (subs.Count > 0 && !subs.Contains(_category))
            {
                _category = subs[0];
            }

            await LoadArticleAsync();
        }
    }

    // ───── sub-category → live KB guidance ─────
    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _category = (TicketCategory)v;
            await LoadArticleAsync();
        }
    }

    private void OnPriorityChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _priority = (TicketPriority)v;
    }

    private async Task LoadArticleAsync()
    {
        _loadingArticle = true;
        try { _article = await Api.GetArticleByCategoryAsync(_category); }
        catch { _article = null; }
        finally { _loadingArticle = false; }
    }

    // ───── submit ─────
    private async Task SubmitAsync()
    {
        if (!CanSubmit || _customer is null) return;
        _submitting = true;
        _error = null;
        try
        {
            string ticketId;
            if (Embedded.IsEmbedded && !string.IsNullOrWhiteSpace(_conversationId))
            {
                // Embedded in Chatwoot with an active conversation: create the
                // ticket AND link it to the conversation so incoming Chatwoot
                // messages are appended to it as internal notes.
                var linkResult = await Api.LinkChatwootTicketAsync(new ChatwootLinkTicketRequest(
                    _customer.Id, _conversationId!, _title.Trim(), _description.Trim(),
                    _category, _priority, _mainCategory));
                ticketId = linkResult.TicketId;
                Toasts.Success(linkResult.AlreadyLinked
                    ? T("Cw.LinkedToConversation") + $" — {ticketId}"
                    : T("TkC.Created", ticketId));
            }
            else
            {
                ticketId = await Api.CreateTicketAsync(new CreateTicketRequest(
                    _customer.Id, _deviceId, _title.Trim(), _description.Trim(), _mainCategory, _category, _priority));
                Toasts.Success(T("TkC.Created", ticketId));
            }
            Nav.NavigateTo($"/tickets/{ticketId}");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        finally { _submitting = false; }
    }

    private void GoBack() =>
        Nav.NavigateTo(Embedded.IsEmbedded ? "/my-tickets" : "/tickets");

    public override void Dispose()
    {
        if (Embedded.IsEmbedded)
        {
            CwContext.OnContextChanged -= OnCwContextChanged;
        }
        base.Dispose();
    }
}
