@page "/knowledge-base"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject ToastService Toasts
@inject EmbeddedStateService Embedded
@inject ChatwootContextService CwContext

<PageTitle>@T("Kb.PageTitle")</PageTitle>

<div class="page-pad anim-fade-up">
    <div class="spread wrap" style="margin-bottom:20px;gap:12px">
        <div>
            <h1 style="font-size:22px">@T("Kb.Title")</h1>
            <p class="muted" style="margin:4px 0 0">@T("Kb.Subtitle")</p>
        </div>
        <AuthorizeView Roles="Admin">
            <button class="btn btn-primary" @onclick="OpenCreate"><i class="bi bi-plus-lg"></i> @T("Kb.NewArticle")</button>
        </AuthorizeView>
    </div>

    <!-- ═══════ CATEGORY CHIPS ═══════ -->
    <div class="row wrap" style="gap:8px;margin-bottom:20px">
        @foreach (var cat in Enum.GetValues<TicketCategory>())
        {
            var c = cat;
            <button class="kb-cat-chip @(_selectedCategory == c ? "active" : "")" @onclick="() => SelectCategoryAsync(c)">
                <i class="bi @UiHelpers.CategoryIcon(c)"></i> @TCategory(c.ToString())
            </button>
        }
    </div>

    <div class="grid" style="grid-template-columns:minmax(0,1.4fr) minmax(0,0.9fr);gap:20px;align-items:start">

        <!-- ═══════ GUIDANCE VIEWER ═══════ -->
        <div>
            @if (_loadingGuidance)
            {
                <div class="grid" style="gap:12px">
                    <Skeleton Height="90px" /><Skeleton Height="90px" /><Skeleton Height="90px" /><Skeleton Height="90px" />
                </div>
            }
            else if (_guidance is null)
            {
                <div class="card empty-state">
                    <div class="icon"><i class="bi bi-file-earmark-text"></i></div>
                    <h3>@T("Kb.NoGuidanceFor", TCategory(_selectedCategory.ToString()))</h3>
                    <p>@T("Kb.NoActiveArticle")</p>
                    <AuthorizeView Roles="Admin">
                        <button class="btn btn-primary" @onclick="OpenCreateForSelected"><i class="bi bi-plus-lg"></i> @T("Kb.CreateNow")</button>
                    </AuthorizeView>
                </div>
            }
            else
            {
                <div class="grid" style="gap:12px">
                    <div class="spread wrap" style="gap:8px">
                        <div>
                            <div style="font-weight:800;font-size:17px">@_guidance.Title</div>
                            <div class="subtle">
                                <i class="bi @UiHelpers.CategoryIcon(_guidance.Category)"></i> @TCategory(_guidance.Category.ToString())
                                · @T("Kb.UpdatedAgo", TimeAgo(_guidance.UpdatedAt ?? _guidance.CreatedAt))
                            </div>
                        </div>
                        <div class="row" style="gap:8px;flex-shrink:0">
                            <button class="kb-copy-btn" title="@T("Cw.CopyAll")" @onclick="() => CopySectionAsync(BuildFullArticle(_guidance), true)">
                                <i class="bi bi-clipboard-check"></i> @T("Cw.CopyAll")
                            </button>
                            <AuthorizeView Roles="Admin">
                                <button class="btn btn-secondary btn-sm" @onclick="EditGuidance"><i class="bi bi-pencil"></i> @T("Common.Edit")</button>
                            </AuthorizeView>
                        </div>
                    </div>
                    <div class="card kb-section-card questions">
                        <div class="spread" style="gap:8px;margin-bottom:8px">
                            <div style="font-weight:700;font-size:13px"><i class="bi bi-question-circle"></i> @T("Kb.Questions")</div>
                            @SectionCopyButton(_guidance.QuestionsToAsk)
                        </div>
                        <MarkdownView Content="@_guidance.QuestionsToAsk" />
                    </div>
                    <div class="card kb-section-card diagnosis">
                        <div class="spread" style="gap:8px;margin-bottom:8px">
                            <div style="font-weight:700;font-size:13px"><i class="bi bi-search"></i> @T("Kb.Diagnosis")</div>
                            @SectionCopyButton(_guidance.DiagnosisSteps)
                        </div>
                        <MarkdownView Content="@_guidance.DiagnosisSteps" />
                    </div>
                    <div class="card kb-section-card answers">
                        <div class="spread" style="gap:8px;margin-bottom:8px">
                            <div style="font-weight:700;font-size:13px"><i class="bi bi-chat-dots"></i> @T("Kb.Answers")</div>
                            @SectionCopyButton(_guidance.SuggestedAnswers, primary: true)
                        </div>
                        <MarkdownView Content="@_guidance.SuggestedAnswers" />
                    </div>
                    <div class="card kb-section-card escalation">
                        <div class="spread" style="gap:8px;margin-bottom:8px">
                            <div style="font-weight:700;font-size:13px"><i class="bi bi-exclamation-octagon"></i> @T("Kb.Escalation")</div>
                            @SectionCopyButton(_guidance.EscalationConditions)
                        </div>
                        <MarkdownView Content="@_guidance.EscalationConditions" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_guidance.Keywords))
                    {
                        <div class="row wrap" style="gap:6px">
                            @foreach (var kw in _guidance.Keywords.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <span class="badge badge-slate">#@kw</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ═══════ ARTICLE DIRECTORY ═══════ -->
        <div class="card" style="padding:18px">
            <div class="section-title" style="margin-bottom:12px"><i class="bi bi-book"></i> @T("Kb.AllArticles")</div>
            <input class="input" placeholder="@T("Kb.SearchPlaceholder")" style="margin-bottom:12px"
                   value="@_search" @oninput="OnSearchInput" />

            @if (_loadingList)
            {
                <Skeleton Height="52px" Style="margin-bottom:8px" />
                <Skeleton Height="52px" Style="margin-bottom:8px" />
                <Skeleton Height="52px" />
            }
            else if (_articles.Count == 0)
            {
                <p class="subtle" style="margin:0">@T("Kb.NoArticles")</p>
            }
            else
            {
                <div class="grid" style="gap:8px">
                    @foreach (var a in _articles)
                    {
                        var art = a;
                        <div class="card hoverable" style="padding:12px 14px;cursor:pointer" @onclick="() => ViewArticleAsync(art)">
                            <div class="spread" style="gap:8px">
                                <div style="min-width:0">
                                    <div style="font-weight:700;font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@art.Title</div>
                                    <div class="subtle"><i class="bi @UiHelpers.CategoryIcon(art.Category)"></i> @TCategory(art.Category.ToString())</div>
                                </div>
                                <div class="row" style="gap:6px;flex-shrink:0">
                                    @if (!art.IsActive)
                                    {
                                        <span class="badge badge-slate">@T("Kb.Inactive")</span>
                                    }
                                    <AuthorizeView Roles="Admin">
                                        <button class="btn btn-ghost btn-sm" @onclick:stopPropagation="true" @onclick="() => OpenEdit(art)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-ghost btn-sm" style="color:var(--danger)" @onclick:stopPropagation="true" @onclick="() => ConfirmDelete(art)"><i class="bi bi-trash"></i></button>
                                    </AuthorizeView>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                @if (_totalPages > 1)
                {
                    <div class="pagination" style="margin-top:12px">
                        <button class="btn btn-ghost btn-sm" disabled="@(_page <= 1)" @onclick="PrevPage"><i class="bi bi-arrow-left flip-rtl"></i></button>
                        <span class="subtle">@_page / @_totalPages</span>
                        <button class="btn btn-ghost btn-sm" disabled="@(_page >= _totalPages)" @onclick="NextPage"><i class="bi bi-arrow-right flip-rtl"></i></button>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- ═══════ CREATE / EDIT MODAL (Admin) ═══════ -->
<Modal @bind-Visible="_showEditor" Title="@(_editingId is null ? T("Kb.NewArticle") : T("Kb.EditArticle"))" Large>
    <div class="row" style="gap:14px;align-items:flex-start">
        <div class="field" style="flex:1">
            <label>@T("TkC.Category") *</label>
            <select class="select" @onchange="OnEditorCategoryChanged" disabled="@(_editingId is not null)">
                @foreach (var cat in Enum.GetValues<TicketCategory>())
                {
                    <option value="@((int)cat)" selected="@(_fCategory == cat)">@TCategory(cat.ToString())</option>
                }
            </select>
        </div>
        <div class="field" style="flex:2">
            <label>@T("Kb.ArticleTitle") *</label>
            <input class="input" maxlength="200" @bind="_fTitle" @bind:event="oninput" placeholder="@T("Kb.ArticleTitlePlaceholder")" />
        </div>
    </div>
    <div class="row" style="gap:14px;align-items:flex-start">
        <div class="field" style="flex:1">
            <label><i class="bi bi-question-circle"></i> @T("Kb.Questions") * <span class="subtle">(Markdown)</span></label>
            <textarea class="textarea mono" rows="6" @bind="_fQuestions" @bind:event="oninput" placeholder="- Question 1&#10;- Question 2"></textarea>
        </div>
        <div class="field" style="flex:1">
            <label><i class="bi bi-search"></i> @T("Kb.Diagnosis") * <span class="subtle">(Markdown)</span></label>
            <textarea class="textarea mono" rows="6" @bind="_fDiagnosis" @bind:event="oninput" placeholder="1. Step one&#10;2. Step two"></textarea>
        </div>
    </div>
    <div class="row" style="gap:14px;align-items:flex-start">
        <div class="field" style="flex:1">
            <label><i class="bi bi-chat-dots"></i> @T("Kb.Answers") * <span class="subtle">(Markdown)</span></label>
            <textarea class="textarea mono" rows="6" @bind="_fAnswers" @bind:event="oninput" placeholder="**If X:** say Y…"></textarea>
        </div>
        <div class="field" style="flex:1">
            <label><i class="bi bi-exclamation-octagon"></i> @T("Kb.Escalation") * <span class="subtle">(Markdown)</span></label>
            <textarea class="textarea mono" rows="6" @bind="_fEscalation" @bind:event="oninput" placeholder="- Escalate when…"></textarea>
        </div>
    </div>
    <div class="row" style="gap:14px;align-items:flex-end">
        <div class="field" style="flex:1;margin-bottom:0">
            <label>@T("Kb.Keywords") <span class="subtle">@T("Kb.KeywordsHint")</span></label>
            <input class="input" @bind="_fKeywords" @bind:event="oninput" placeholder="screen, cracked, display" />
        </div>
        <label class="row" style="gap:8px;padding-bottom:10px;cursor:pointer">
            <input type="checkbox" @bind="_fActive" /> <span style="font-size:13px;font-weight:600">@T("Kb.Active")</span>
        </label>
    </div>
    <div class="row" style="justify-content:flex-end;gap:10px;margin-top:16px">
        <button class="btn btn-ghost" @onclick="CloseEditor" disabled="@_saving">@T("Common.Cancel")</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(!EditorValid || _saving)">
            @(_saving ? T("Common.Saving") : _editingId is null ? T("Kb.CreateArticle") : T("Kb.SaveChanges"))
        </button>
    </div>
</Modal>

<!-- ═══════ DELETE CONFIRM ═══════ -->
<Modal @bind-Visible="_showDelete" Title="@T("Kb.DeleteArticle")">
    <p style="font-size:13.5px">@T("Kb.DeleteConfirm") “<b>@_deleteTarget?.Title</b>”</p>
    <div class="row" style="justify-content:flex-end;gap:10px;margin-top:14px">
        <button class="btn btn-ghost" @onclick="CancelDelete" disabled="@_deleting">@T("Common.Cancel")</button>
        <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_deleting">@(_deleting ? T("Common.Deleting") : T("Common.Delete"))</button>
    </div>
</Modal>

@code {
    // guidance viewer
    private TicketCategory _selectedCategory = TicketCategory.ScreenDamage;
    private KnowledgeBaseArticleDto? _guidance;
    private bool _loadingGuidance = true;

    // article directory
    private List<KnowledgeBaseArticleDto> _articles = [];
    private string _search = string.Empty;
    private int _page = 1;
    private int _totalPages = 1;
    private bool _loadingList = true;
    private System.Threading.Timer? _debounce;

    // editor
    private bool _showEditor;
    private Guid? _editingId;
    private TicketCategory _fCategory = TicketCategory.ScreenDamage;
    private string _fTitle = string.Empty;
    private string _fQuestions = string.Empty;
    private string _fDiagnosis = string.Empty;
    private string _fAnswers = string.Empty;
    private string _fEscalation = string.Empty;
    private string _fKeywords = string.Empty;
    private bool _fActive = true;
    private bool _saving;

    // delete
    private bool _showDelete;
    private KnowledgeBaseArticleDto? _deleteTarget;
    private bool _deleting;

    private bool EditorValid =>
        !string.IsNullOrWhiteSpace(_fTitle) &&
        !string.IsNullOrWhiteSpace(_fQuestions) &&
        !string.IsNullOrWhiteSpace(_fDiagnosis) &&
        !string.IsNullOrWhiteSpace(_fAnswers) &&
        !string.IsNullOrWhiteSpace(_fEscalation);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadGuidanceAsync(), LoadListAsync());
    }

    // ───── copy-to-chat (embedded agent workflow) ─────

    /// <summary>
    /// Small copy/insert button rendered on each guidance section. When the CRM
    /// runs embedded inside Chatwoot it labels the action "Insert into reply"
    /// (text is pushed into the agent editor + copied); otherwise it's a plain
    /// "Copy this section" clipboard action. <paramref name="primary"/> gives the
    /// Suggested-Answers button a slightly stronger affordance.
    /// </summary>
    private RenderFragment SectionCopyButton(string? content, bool primary = false) => builder =>
    {
        if (string.IsNullOrWhiteSpace(content)) return;
        var label = Embedded.IsEmbedded ? T("Cw.InsertToReply") : T("Cw.CopySection");
        var icon = Embedded.IsEmbedded ? "bi-box-arrow-in-down-left" : "bi-clipboard";
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "class", "kb-copy-btn" + (primary ? " primary" : ""));
        builder.AddAttribute(2, "title", label);
        builder.AddAttribute(3, "onclick",
            EventCallback.Factory.Create(this, () => CopySectionAsync(content, false)));
        builder.OpenElement(4, "i");
        builder.AddAttribute(5, "class", "bi " + icon);
        builder.CloseElement();
        builder.AddContent(6, " " + label);
        builder.CloseElement();
    };

    /// <summary>
    /// Copies a KB section to the clipboard — and, when embedded in Chatwoot,
    /// also pushes it straight into the agent reply editor. Shows a toast so the
    /// agent gets immediate feedback.
    /// </summary>
    private async Task CopySectionAsync(string? content, bool fullArticle)
    {
        if (string.IsNullOrWhiteSpace(content)) return;
        var text = content.Trim();
        bool ok;
        if (Embedded.IsEmbedded)
        {
            ok = await CwContext.SendToReplyAsync(text);
            if (ok) { Toasts.Success(T("Cw.SentToReply")); return; }
        }
        else
        {
            ok = await CwContext.CopyToClipboardAsync(text);
        }

        if (ok) Toasts.Success(T("Cw.Copied"));
        else Toasts.Error(T("Cw.CopyFailed"));
    }

    /// <summary>Builds a clean plain-text rendering of the whole guidance article.</summary>
    private string BuildFullArticle(KnowledgeBaseArticleDto a)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"# {a.Title}").AppendLine();
        void Section(string heading, string? body)
        {
            if (string.IsNullOrWhiteSpace(body)) return;
            sb.AppendLine($"## {heading}").AppendLine(body.Trim()).AppendLine();
        }
        Section(T("Kb.Questions"), a.QuestionsToAsk);
        Section(T("Kb.Diagnosis"), a.DiagnosisSteps);
        Section(T("Kb.Answers"), a.SuggestedAnswers);
        Section(T("Kb.Escalation"), a.EscalationConditions);
        return sb.ToString().TrimEnd();
    }

    // ───── guidance ─────
    private async Task SelectCategoryAsync(TicketCategory c)
    {
        _selectedCategory = c;
        await LoadGuidanceAsync();
    }

    private async Task LoadGuidanceAsync()
    {
        _loadingGuidance = true;
        StateHasChanged();
        try { _guidance = await Api.GetArticleByCategoryAsync(_selectedCategory); }
        catch { _guidance = null; }
        finally { _loadingGuidance = false; StateHasChanged(); }
    }

    private async Task ViewArticleAsync(KnowledgeBaseArticleDto a)
    {
        _selectedCategory = a.Category;
        _guidance = a;
        _loadingGuidance = false;
        await Task.CompletedTask;
    }

    // ───── directory ─────
    private void OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _debounce?.Dispose();
        _debounce = new System.Threading.Timer(_ => InvokeAsync(async () =>
        {
            _page = 1;
            await LoadListAsync();
        }), null, 350, Timeout.Infinite);
    }

    private async Task LoadListAsync()
    {
        _loadingList = true;
        StateHasChanged();
        try
        {
            var result = await Api.GetArticlesAsync(_page, 10, string.IsNullOrWhiteSpace(_search) ? null : _search.Trim());
            _articles = result.Articles;
            _totalPages = Math.Max(result.TotalPages, 1);
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _loadingList = false; StateHasChanged(); }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadListAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadListAsync(); } }

    // ───── editor ─────
    private void OpenCreate()
    {
        _editingId = null;
        _fCategory = _selectedCategory;
        _fTitle = _fQuestions = _fDiagnosis = _fAnswers = _fEscalation = _fKeywords = string.Empty;
        _fActive = true;
        _showEditor = true;
    }

    private void OpenCreateForSelected() => OpenCreate();

    private void EditGuidance()
    {
        if (_guidance is not null) OpenEdit(_guidance);
    }

    private void OpenEdit(KnowledgeBaseArticleDto a)
    {
        _editingId = a.Id;
        _fCategory = a.Category;
        _fTitle = a.Title;
        _fQuestions = a.QuestionsToAsk;
        _fDiagnosis = a.DiagnosisSteps;
        _fAnswers = a.SuggestedAnswers;
        _fEscalation = a.EscalationConditions;
        _fKeywords = a.Keywords;
        _fActive = a.IsActive;
        _showEditor = true;
    }

    private void CloseEditor() => _showEditor = false;

    private void OnEditorCategoryChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v)) _fCategory = (TicketCategory)v;
    }

    private async Task SaveAsync()
    {
        if (!EditorValid) return;
        _saving = true;
        try
        {
            if (_editingId is Guid id)
            {
                await Api.UpdateArticleAsync(new UpdateArticleRequest(
                    id, _fTitle.Trim(), _fQuestions, _fDiagnosis, _fAnswers, _fEscalation,
                    string.IsNullOrWhiteSpace(_fKeywords) ? null : _fKeywords.Trim(), _fActive));
                Toasts.Success(T("Kb.ArticleUpdated"));
            }
            else
            {
                await Api.CreateArticleAsync(new CreateArticleRequest(
                    _fCategory, _fTitle.Trim(), _fQuestions, _fDiagnosis, _fAnswers, _fEscalation,
                    string.IsNullOrWhiteSpace(_fKeywords) ? null : _fKeywords.Trim(), _fActive));
                Toasts.Success(T("Kb.ArticleCreated"));
            }
            _showEditor = false;
            await Task.WhenAll(LoadListAsync(), LoadGuidanceAsync());
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _saving = false; }
    }

    // ───── delete ─────
    private void ConfirmDelete(KnowledgeBaseArticleDto a)
    {
        _deleteTarget = a;
        _showDelete = true;
    }

    private void CancelDelete() => _showDelete = false;

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        _deleting = true;
        try
        {
            await Api.DeleteArticleAsync(_deleteTarget.Id);
            Toasts.Success(T("Kb.ArticleDeleted"));
            _showDelete = false;
            await Task.WhenAll(LoadListAsync(), LoadGuidanceAsync());
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _deleting = false; }
    }
}
