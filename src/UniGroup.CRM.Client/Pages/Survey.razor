@page "/survey/{Token}"
@layout EmptyLayout
@inherits LocalizedComponentBase
@inject CrmApiClient Api

<PageTitle>@T("Survey.PageTitle")</PageTitle>

<div class="auth-page">
    <div class="auth-orb"></div>
    <div class="auth-card glass anim-scale-in" style="max-width:480px">
        @if (_done)
        {
            <div style="text-align:center;padding:12px 0">
                <div style="font-size:56px;margin-bottom:10px"><i class="bi @(_success ? "bi-emoji-laughing" : "bi-emoji-frown")" style="color:@(_success ? "var(--success, #10b981)" : "var(--warning, #f59e0b)")"></i></div>
                <h2 style="font-size:20px;margin:0 0 8px">@(_success ? T("Survey.ThankYou") : T("Survey.Error"))</h2>
                <p class="muted" style="margin:0;line-height:1.6">@_message</p>
                @if (_success && _rating >= 4)
                {
                    <p class="muted" style="margin-top:10px">@T("Survey.Great") <i class="bi bi-star-fill" style="color:#f59e0b"></i></p>
                }
                else if (_success)
                {
                    <p class="muted" style="margin-top:10px">@T("Survey.Improve")</p>
                }
            </div>
        }
        else
        {
            <div class="auth-logo" style="margin-bottom:6px">
                <span class="grad-text" style="font-family:var(--font-display);font-weight:800;font-size:22px">UniGroup</span>
            </div>
            <h2 style="text-align:center;font-size:19px;margin:0 0 6px">@T("Survey.How")</h2>
            <p class="muted" style="text-align:center;margin:0 0 22px;font-size:13px">
                @T("Survey.Resolved")
            </p>

            <!-- ═══ STARS ═══ -->
            <div class="stars" style="margin-bottom:6px">
                @for (var i = 1; i <= 5; i++)
                {
                    var star = i;
                    <button type="button" class="star-btn @(star <= DisplayRating ? "lit" : "")"
                            @onclick="() => SetRating(star)"
                            @onmouseover="() => _hover = star"
                            @onmouseout="ClearHover"
                            aria-label="@star"><i class="bi bi-star-fill"></i></button>
                }
            </div>
            <div style="text-align:center;font-size:13px;font-weight:700;min-height:20px;margin-bottom:16px;color:var(--text-2)">
                @RatingLabel
            </div>

            <div class="field">
                <label>@T("Survey.Feedback")</label>
                <textarea class="textarea" rows="4" maxlength="2000"
                          placeholder="@T("Survey.FeedbackPlaceholder")"
                          @bind="_feedback" @bind:event="oninput"></textarea>
            </div>

            @if (_error is not null)
            {
                <div class="badge badge-red" style="display:block;padding:10px 14px;margin-bottom:14px;white-space:normal"><i class="bi bi-exclamation-triangle"></i> @_error</div>
            }

            <button class="btn btn-primary btn-lg" style="width:100%"
                    @onclick="SubmitAsync" disabled="@(_rating == 0 || _submitting)">
                @(_submitting ? T("Survey.Submitting") : T("Survey.Submit"))
            </button>
            <p class="subtle" style="text-align:center;margin:14px 0 0">
                @T("Survey.OneTime")
            </p>
        }
    </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private int _rating;
    private int _hover;
    private string _feedback = string.Empty;

    private bool _submitting;
    private bool _done;
    private bool _success;
    private string _message = string.Empty;
    private string? _error;

    private int DisplayRating => _hover > 0 ? _hover : _rating;

    private string RatingLabel => DisplayRating switch
    {
        1 => T("Survey.Rate1"),
        2 => T("Survey.Rate2"),
        3 => T("Survey.Rate3"),
        4 => T("Survey.Rate4"),
        5 => T("Survey.Rate5"),
        _ => T("Survey.TapStar"),
    };

    private void SetRating(int stars) => _rating = stars;
    private void ClearHover() => _hover = 0;

    private async Task SubmitAsync()
    {
        if (_rating is < 1 or > 5) return;
        _submitting = true;
        _error = null;
        try
        {
            var result = await Api.SubmitSurveyAsync(new SubmitSurveyRequest(
                Token.Trim(), _rating, string.IsNullOrWhiteSpace(_feedback) ? null : _feedback.Trim()));

            _success = result.Success;
            _message = result.Message;
            _done = true;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException)
        {
            _error = T("Common.CannotReachApi");
        }
        finally { _submitting = false; }
    }
}
