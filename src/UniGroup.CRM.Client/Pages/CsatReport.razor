@page "/csat-report"
@attribute [Authorize(Roles = "Admin,Team Leader,TeamLeader")]
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject ToastService Toasts

<PageTitle>@T("Csat.PageTitle")</PageTitle>

<div class="page-pad anim-fade-up">
    <div class="spread wrap" style="margin-bottom:20px;gap:12px">
        <div>
            <h1 style="font-size:22px">@T("Csat.Title")</h1>
            <p class="muted" style="margin:4px 0 0">@T("Csat.Subtitle")</p>
        </div>
        <div class="row" style="gap:8px">
            <input type="date" class="input" style="width:160px" value="@_from.ToString("yyyy-MM-dd")" @onchange="OnFromChanged" />
            <input type="date" class="input" style="width:160px" value="@_to.ToString("yyyy-MM-dd")" @onchange="OnToChanged" />
            <button class="btn btn-secondary" @onclick="LoadAsync" disabled="@_loading">@(_loading ? "…" : T("Common.Apply"))</button>
        </div>
    </div>

    @if (_loading && _report is null)
    {
        <div class="stat-grid" style="margin-bottom:16px">
            @for (var i = 0; i < 4; i++) { <Skeleton Height="92px" /> }
        </div>
        <Skeleton Height="220px" />
    }
    else if (_report is null)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-star"></i></div>
            <h3>@T("Csat.NoData")</h3>
            <p>@T("Csat.LoadError")</p>
            <button class="btn btn-primary" @onclick="LoadAsync">@T("Common.Retry")</button>
        </div>
    }
    else
    {
        <div class="stat-grid" style="margin-bottom:16px">
            <div class="card stat-card">
                <div class="stat-label">@T("Csat.Sent")</div>
                <div class="stat-value">@_report.TotalSent</div>
                <div class="stat-icon" style="background:rgba(99,102,241,.15)"><i class="bi bi-send"></i></div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">@T("Csat.Responses")</div>
                <div class="stat-value">@_report.TotalSubmitted</div>
                <div class="stat-icon" style="background:rgba(59,130,246,.15)"><i class="bi bi-inbox"></i></div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">@T("Csat.ResponseRate")</div>
                <div class="stat-value">@(_report.ResponseRate.ToString("0.#"))%</div>
                <div class="stat-icon" style="background:rgba(16,185,129,.15)"><i class="bi bi-graph-up"></i></div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">@T("Csat.AvgRating")</div>
                <div class="stat-value"><i class="bi bi-star-fill" style="color:#f59e0b"></i> @(_report.AverageRating.ToString("0.00"))</div>
                <div class="stat-sub">@T("Csat.OutOf5")</div>
                <div class="stat-icon" style="background:rgba(245,158,11,.15)"><i class="bi bi-trophy"></i></div>
            </div>
        </div>

        <div class="card" style="padding:22px;max-width:640px">
            <div class="section-title" style="margin-bottom:14px">@T("Csat.Distribution")</div>
            @if (_report.TotalSubmitted == 0)
            {
                <p class="subtle" style="margin:0">@T("Csat.NoResponses")</p>
            }
            else
            {
                var max = Math.Max(_report.RatingDistribution.Values.DefaultIfEmpty(0).Max(), 1);
                @for (var stars = 5; stars >= 1; stars--)
                {
                    var count = _report.RatingDistribution.TryGetValue(stars, out var c) ? c : 0;
                    <div class="rating-dist-row">
                        <span class="rt">@stars <i class="bi bi-star-fill" style="color:#f59e0b;font-size:11px"></i></span>
                        <div class="track">
                            <div class="fill" style="width:@((count * 100.0 / max).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                        </div>
                        <span class="mono" style="width:40px;text-align:end">@count</span>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private CsatReportDto? _report;
    private DateTime _from = DateTime.UtcNow.Date.AddDays(-30);
    private DateTime _to = DateTime.UtcNow.Date;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void OnFromChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d)) _from = d.Date;
    }

    private void OnToChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d)) _to = d.Date;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _report = await Api.GetCsatReportAsync(_from, _to.AddDays(1).AddSeconds(-1));
        }
        catch (ApiException ex)
        {
            _report = null;
            Toasts.Error(ex.Message);
        }
        finally { _loading = false; }
    }
}
