@page "/customers"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>@T("Cust.PageTitle")</PageTitle>

<div class="page-pad anim-fade-up">
    <div class="spread" style="margin-bottom:20px">
        <div>
            <h1 style="font-size:22px">@T("Cust.Title")</h1>
            <p class="muted" style="margin:4px 0 0">@T("Cust.Subtitle")</p>
        </div>
        <button class="btn btn-primary" @onclick="() => _showCreate = true"><i class="bi bi-plus-lg"></i> @T("Cust.New")</button>
    </div>

    <div class="card filter-bar" style="margin-bottom:16px">
        <div style="position:relative;flex:1;min-width:220px">
            <input class="input" placeholder="@T("Cust.SearchPlaceholder")"
                   value="@_term" @oninput="OnInput" @onkeydown="OnKeyDown" />
        </div>
        <button class="btn btn-secondary" @onclick="SearchAsync" disabled="@_loading"><i class="bi bi-search"></i> @T("Common.Search")</button>
    </div>

    @if (_loading)
    {
        <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr))">
            @for (var i = 0; i < 6; i++)
            {
                <div class="card" style="padding:18px">
                    <div class="row"><Skeleton Circle Width="40px" Height="40px" /><div style="flex:1"><Skeleton Width="60%" Height="14px" Style="margin-bottom:8px" /><Skeleton Width="40%" Height="11px" /></div></div>
                </div>
            }
        </div>
    }
    else if (_results is null)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-people"></i></div>
            <h3>@T("Cust.FindTitle")</h3>
            <p>@T("Cust.FindText")</p>
        </div>
    }
    else if (_results.Count == 0)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-search"></i></div>
            <h3>@T("Cust.NoneTitle")</h3>
            <p>@T("Cust.NoneText", _lastTerm)</p>
            <button class="btn btn-primary" @onclick="() => _showCreate = true"><i class="bi bi-plus-lg"></i> @T("Cust.Create")</button>
        </div>
    }
    else
    {
        <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(300px,1fr))">
            @foreach (var c in _results)
            {
                <div class="card hoverable" style="padding:18px;cursor:pointer" @onclick="() => GoTo(c.Id)">
                    <div class="row" style="margin-bottom:12px">
                        <div class="avatar">@UiHelpers.Initials(c.Name)</div>
                        <div style="min-width:0;flex:1">
                            <div style="font-weight:700;font-size:14.5px">@c.Name</div>
                            <div class="subtle">@(c.Email ?? T("Common.NoEmail"))</div>
                        </div>
                    </div>
                    <div class="row wrap" style="gap:6px">
                        @if (c.Phones.FirstOrDefault(p => p.IsPrimary) is { } primary)
                        {
                            <span class="badge badge-indigo mono"><i class="bi bi-telephone"></i> @primary.Phone</span>
                        }
                        <span class="badge badge-slate">@T("Common.DevicesCount", c.Devices.Count)</span>
                        @if (c.Devices.Any(d => d.WarrantyStatus == "Active"))
                        {
                            <span class="badge badge-green"><span class="dot"></span> @T("Cust.Warranty")</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.City))
                        {
                            <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> @c.City</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<Modal @bind-Visible="_showCreate" Title="@T("Cust.New")">
    <EditForm Model="_create" OnValidSubmit="CreateAsync">
        <DataAnnotationsValidator />
        <div class="field">
            <label>@T("Cust.FullName")</label>
            <InputText class="input" @bind-Value="_create.Name" placeholder="@T("Cust.FullNamePlaceholder")" />
            <LocalizedValidationMessage For="() => _create.Name" />
        </div>
        <div class="field">
            <label>@T("Cust.PrimaryPhone")</label>
            <InputText class="input mono" @bind-Value="_create.Phone" placeholder="01012345678" />
            <LocalizedValidationMessage For="() => _create.Phone" />
        </div>
        <div class="field">
            <label>@T("Cust.Email")</label>
            <InputText class="input" @bind-Value="_create.Email" placeholder="customer@email.com" />
        </div>
        <div class="row" style="align-items:flex-start">
            <div class="field" style="flex:1">
                <label>@T("Cust.Province")</label>
                <InputText class="input" @bind-Value="_create.Province" placeholder="Cairo" />
            </div>
            <div class="field" style="flex:1">
                <label>@T("Cust.City")</label>
                <InputText class="input" @bind-Value="_create.City" placeholder="Maadi" />
            </div>
        </div>
        <div class="field">
            <label>@T("Cust.AddressDetails")</label>
            <InputText class="input" @bind-Value="_create.AddressDetails" placeholder="@T("Cust.AddressPlaceholder")" />
        </div>
        <button class="btn btn-primary" style="width:100%" type="submit" disabled="@_creating">
            @(_creating ? T("Cust.Creating") : T("Cust.CreateBtn"))
        </button>
    </EditForm>
</Modal>

@code {
    private sealed class CreateModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.NameRequired")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.PhoneRequired")]
        public string Phone { get; set; } = string.Empty;

        public string? Email { get; set; }
        public string? Province { get; set; }
        public string? City { get; set; }
        public string? AddressDetails { get; set; }
    }

    private string _term = string.Empty;
    private string _lastTerm = string.Empty;
    private bool _loading;
    private List<CustomerDetailsDto>? _results;
    private bool _showCreate;
    private bool _creating;
    private CreateModel _create = new();

    private void GoTo(Guid id) => Nav.NavigateTo($"/customers/{id}");

    private void OnInput(ChangeEventArgs e) => _term = e.Value?.ToString() ?? string.Empty;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private async Task SearchAsync()
    {
        var term = _term.Trim();
        if (term.Length < 2)
        {
            Toasts.Info(T("Cust.MinChars"));
            return;
        }

        _loading = true;
        _lastTerm = term;
        try
        {
            _results = await Api.SearchCustomersAsync(term);
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message);
            _results = [];
        }
        catch (HttpRequestException)
        {
            Toasts.Error(T("Common.CannotReachApi"));
            _results = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateAsync()
    {
        _creating = true;
        try
        {
            var id = await Api.CreateCustomerAsync(new CreateCustomerRequest(
                _create.Name.Trim(),
                string.IsNullOrWhiteSpace(_create.Email) ? null : _create.Email.Trim(),
                _create.Province, _create.City, _create.AddressDetails,
                _create.Phone.Trim()));

            Toasts.Success(T("Cust.Created"));
            _showCreate = false;
            _create = new CreateModel();
            Nav.NavigateTo($"/customers/{id}");
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message);
        }
        finally
        {
            _creating = false;
        }
    }
}
