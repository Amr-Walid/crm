@page "/customers"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts
@inject EmbeddedStateService Embedded
@inject ChatwootContextService CwContext
@inject IJSRuntime JS

<PageTitle>@T("Cust.PageTitle")</PageTitle>

<div class="page-pad anim-fade-up">
    @if (Embedded.IsEmbedded && CwContext.HasContext)
    {
        <div class="cw-context-banner">
            <i class="bi bi-chat-left-dots"></i>
            <div style="flex:1;min-width:0">
                <strong>@(string.IsNullOrEmpty(CwContext.ContactName) ? T("Cw.FromChatwoot") : CwContext.ContactName)</strong>
                <span class="subtle">
                    @if (!string.IsNullOrEmpty(CwContext.ContactPhone)) { <span class="mono">@CwContext.ContactPhone</span> }
                    @if (!string.IsNullOrEmpty(CwContext.ContactEmail)) { <span> · @CwContext.ContactEmail</span> }
                </span>
            </div>
            <button class="btn btn-ghost btn-sm" @onclick="MatchFromContextAsync" disabled="@_loading" title="@T("Cw.AutoMatched")">
                <i class="bi bi-arrow-repeat"></i>
            </button>
        </div>
    }

    <div class="spread" style="margin-bottom:20px">
        <div>
            <h1 style="font-size:22px">@T("Cust.Title")</h1>
            <p class="muted" style="margin:4px 0 0">@T("Cust.Subtitle")</p>
        </div>
        <div class="row" style="gap:10px">
            <button class="btn btn-ghost" @onclick="OpenImport"><i class="bi bi-upload"></i> @T("Cust.Import")</button>
            <button class="btn btn-primary" @onclick="() => _showCreate = true"><i class="bi bi-plus-lg"></i> @T("Cust.New")</button>
        </div>
    </div>

    <div class="card filter-bar" style="margin-bottom:16px">
        <div style="position:relative;flex:1;min-width:220px">
            <input class="input" placeholder="@T("Cust.SearchPlaceholder")"
                   value="@_term" @oninput="OnSearchInput" @onkeydown="OnKeyDown" />
        </div>
        <button class="btn btn-secondary" @onclick="SearchAsync" disabled="@_loading"><i class="bi bi-search"></i> @T("Common.Search")</button>
    </div>

    @if (_loading)
    {
        <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr))">
            @for (var i = 0; i < 6; i++)
            {
                <div class="card" style="padding:18px">
                    <div class="row"><Skeleton Circle Width="40px" Height="40px" /><div style="flex:1"><Skeleton Width="60%" Height="14px" Style="margin-bottom:8px" /><Skeleton Width="40%" Height="11px" /></div></div>
                </div>
            }
        </div>
    }
    else if (_results is null)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-people"></i></div>
            <h3>@T("Cust.FindTitle")</h3>
            <p>@T("Cust.FindText")</p>
        </div>
    }
    else if (_results.Count == 0)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-search"></i></div>
            <h3>@T("Cust.NoneTitle")</h3>
            <p>@T("Cust.NoneText", _lastTerm)</p>
            <button class="btn btn-primary" @onclick="() => _showCreate = true"><i class="bi bi-plus-lg"></i> @T("Cust.Create")</button>
        </div>
    }
    else
    {
        <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(300px,1fr))">
            @foreach (var c in _results)
            {
                var cust = c;
                <div class="card hoverable" style="padding:18px;cursor:pointer" @onclick="() => GoTo(cust.Id)">
                    <div class="row" style="margin-bottom:12px">
                        <div class="avatar">@UiHelpers.Initials(cust.Name)</div>
                        <div style="min-width:0;flex:1">
                            <div style="font-weight:700;font-size:14.5px">@cust.Name</div>
                            <div class="subtle">@(cust.Email ?? T("Common.NoEmail"))</div>
                        </div>
                    </div>
                    <div class="row wrap" style="gap:6px">
                        @if (cust.Phones.FirstOrDefault(p => p.IsPrimary) is { } primary)
                        {
                            <span class="badge badge-indigo mono"><i class="bi bi-telephone"></i> @primary.Phone</span>
                        }
                        <span class="badge badge-slate">@T("Common.DevicesCount", cust.Devices.Count)</span>
                        @if (cust.Devices.Any(d => d.WarrantyStatus == "Active"))
                        {
                            <span class="badge badge-green"><span class="dot"></span> @T("Cust.Warranty")</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(cust.City))
                        {
                            <span class="badge badge-slate"><i class="bi bi-geo-alt"></i> @cust.City</span>
                        }
                    </div>
                    @if (Embedded.IsEmbedded && !string.IsNullOrEmpty(CwContext.ConversationId))
                    {
                        <div class="row" style="gap:8px;margin-top:12px" @onclick:stopPropagation="true">
                            <button class="btn btn-primary btn-sm" style="flex:1" @onclick="() => CreateTicketFor(cust.Id)">
                                <i class="bi bi-ticket-perforated"></i> @T("TkC.Title")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
        @if (_totalPages > 1)
        {
            <div class="row" style="justify-content:center;margin-top:20px;gap:12px">
                <button class="btn btn-ghost btn-sm" disabled="@(_page <= 1)" @onclick="PrevPage"><i class="bi bi-arrow-left flip-rtl"></i></button>
                <span class="subtle">@_page / @_totalPages</span>
                <button class="btn btn-ghost btn-sm" disabled="@(_page >= _totalPages)" @onclick="NextPage"><i class="bi bi-arrow-right flip-rtl"></i></button>
            </div>
        }
    }
</div>

<Modal @bind-Visible="_showCreate" Title="@T("Cust.New")">
    <EditForm Model="_create" OnValidSubmit="CreateAsync">
        <DataAnnotationsValidator />
        <div class="field">
            <label>@T("Cust.FullName")</label>
            <InputText class="input" @bind-Value="_create.Name" placeholder="@T("Cust.FullNamePlaceholder")" />
            <LocalizedValidationMessage For="() => _create.Name" />
        </div>
        <div class="field">
            <label>@T("Cust.PrimaryPhone")</label>
            <InputText class="input mono" @bind-Value="_create.Phone" placeholder="01012345678" />
            <LocalizedValidationMessage For="() => _create.Phone" />
        </div>
        <div class="field">
            <label>@T("Cust.Email")</label>
            <InputText class="input" @bind-Value="_create.Email" placeholder="customer@email.com" />
        </div>
        <div class="row" style="align-items:flex-start">
            <div class="field" style="flex:1">
                <label>@T("Cust.Province")</label>
                <InputText class="input" @bind-Value="_create.Province" placeholder="Cairo" />
            </div>
            <div class="field" style="flex:1">
                <label>@T("Cust.City")</label>
                <InputText class="input" @bind-Value="_create.City" placeholder="Maadi" />
            </div>
        </div>
        <div class="field">
            <label>@T("Cust.AddressDetails")</label>
            <InputText class="input" @bind-Value="_create.AddressDetails" placeholder="@T("Cust.AddressPlaceholder")" />
        </div>
        <div class="field">
            <label><i class="bi bi-tags"></i> @T("Customers.Group")</label>
            <InputText class="input" @bind-Value="_create.CustomerGroup" placeholder="@T("Customers.GroupPlaceholder")" />
        </div>
        <button class="btn btn-primary" style="width:100%" type="submit" disabled="@_creating">
            @(_creating ? T("Cust.Creating") : T("Cust.CreateBtn"))
        </button>
    </EditForm>
</Modal>

<Modal @bind-Visible="_showImport" Title="@T("Cust.Import")">
    <div class="import-panel">
        <p class="muted" style="margin:0 0 12px">@T("Cust.ImportIntro")</p>

        <div class="import-step">
            <span class="import-step-num">1</span>
            <div style="flex:1">
                <div style="font-weight:600">@T("Cust.ImportStep1")</div>
                <button class="btn btn-ghost btn-sm" style="margin-top:8px" @onclick="DownloadTemplateAsync" disabled="@_downloadingTemplate">
                    @if (_downloadingTemplate)
                    {
                        <span class="spinner-sm"></span> <span>@T("Common.Loading")</span>
                    }
                    else
                    {
                        <i class="bi bi-file-earmark-excel"></i> <span>@T("Cust.ImportDownloadTemplate")</span>
                    }
                </button>
            </div>
        </div>

        <div class="import-step">
            <span class="import-step-num">2</span>
            <div style="flex:1">
                <div style="font-weight:600">@T("Cust.ImportStep2")</div>
                <label class="file-drop" style="margin-top:8px">
                    <InputFile OnChange="OnImportFileSelected" accept=".xlsx" />
                    <i class="bi bi-cloud-arrow-up"></i>
                    <span>@(string.IsNullOrEmpty(_importFileName) ? T("Cust.ImportChooseFile") : _importFileName)</span>
                </label>
            </div>
        </div>

        <div class="import-step">
            <span class="import-step-num">3</span>
            <div style="flex:1">
                <div style="font-weight:600">@T("Cust.ImportStep3")</div>
                <button class="btn btn-primary btn-sm" style="margin-top:8px" @onclick="ImportAsync" disabled="@(_importing || _importStream is null)">
                    @if (_importing)
                    {
                        <span class="spinner-sm"></span> <span>@T("Cust.ImportUploading")</span>
                    }
                    else
                    {
                        <i class="bi bi-upload"></i> <span>@T("Cust.ImportSubmit")</span>
                    }
                </button>
            </div>
        </div>

        @if (_importResult is not null)
        {
            <div class="alert @(_importResult.FailedCount > 0 ? "alert-warning" : "alert-success")" style="margin-top:16px">
                <div style="font-weight:600">
                    <i class="bi @(_importResult.FailedCount > 0 ? "bi-exclamation-triangle" : "bi-check-circle")"></i>
                    @T("Cust.ImportResult", _importResult.SuccessCount, _importResult.FailedCount)
                </div>
                @if (_importResult.Errors.Count > 0)
                {
                    <ul class="import-errors">
                        @foreach (var err in _importResult.Errors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                }
            </div>
        }
    </div>
</Modal>

@code {
    private sealed class CreateModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.NameRequired")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.PhoneRequired")]
        public string Phone { get; set; } = string.Empty;

        public string? Email { get; set; }
        public string? Province { get; set; }
        public string? City { get; set; }
        public string? AddressDetails { get; set; }
        public string? CustomerGroup { get; set; }
    }

    private string _term = string.Empty;
    private string _lastTerm = string.Empty;
    private bool _loading;
    private List<CustomerDetailsDto>? _results;
    private int _page = 1;
    private int _totalPages = 1;
    private bool _showCreate;
    private bool _creating;
    private CreateModel _create = new();

    // Bulk import (Excel) state.
    private bool _showImport;
    private bool _importing;
    private bool _downloadingTemplate;
    private string? _importFileName;
    private System.IO.Stream? _importStream;
    private ImportCustomersResult? _importResult;

    // Tracks the last Chatwoot contact we auto-matched so a re-render (e.g. theme
    // toggle) doesn't re-trigger the search for the same conversation.
    private string? _lastMatchedKey;

    protected override void OnInitialized()
    {
        base.OnInitialized(); // keep language-change subscription from the base
        if (Embedded.IsEmbedded)
        {
            CwContext.OnContextChanged += OnCwContextChanged;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // If Chatwoot context already arrived before this page mounted, use it.
        if (Embedded.IsEmbedded && CwContext.HasContext)
        {
            await MatchFromContextAsync();
        }
        else
        {
            // Standalone (non-embedded) use: auto-load the full customer directory
            // so agents land on a populated list instead of an empty search prompt.
            await SearchAsync();
        }
    }

    private void OnCwContextChanged() => InvokeAsync(async () =>
    {
        await MatchFromContextAsync();
        StateHasChanged();
    });

    /// <summary>
    /// Auto-searches for the customer behind the active Chatwoot conversation by
    /// phone (preferred) or email. If none is found, the registration form is
    /// opened pre-filled with the Chatwoot contact identity so the agent can
    /// register the customer in one step.
    /// </summary>
    private async Task MatchFromContextAsync()
    {
        var phone = CwContext.ContactPhone;
        var email = CwContext.ContactEmail;
        var searchTerm = !string.IsNullOrWhiteSpace(phone) ? phone : email;
        if (string.IsNullOrWhiteSpace(searchTerm)) return;

        var key = $"{CwContext.ConversationId}|{phone}|{email}";
        if (key == _lastMatchedKey && _results is not null) return;
        _lastMatchedKey = key;

        _term = searchTerm.Trim();
        _loading = true;
        _lastTerm = _term;
        StateHasChanged();
        try
        {
            var result = await Api.SearchCustomersAsync(_term, 1, 9);
            _results = result.Customers;
            _totalPages = Math.Max(result.TotalPages, 1);
            _page = 1;
            if (_results.Count == 0)
            {
                // No CRM customer matches this conversation — pre-fill registration.
                PrefillCreateFromContext();
                _showCreate = true;
                Toasts.Info(T("Cw.NoMatchPrefill"));
            }
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); _results = []; }
        catch (HttpRequestException) { Toasts.Error(T("Common.CannotReachApi")); _results = []; }
        finally { _loading = false; StateHasChanged(); }
    }

    private void PrefillCreateFromContext()
    {
        _create = new CreateModel
        {
            Name = CwContext.ContactName ?? string.Empty,
            Phone = CwContext.ContactPhone ?? string.Empty,
            Email = CwContext.ContactEmail
        };
    }

    /// <summary>Navigate to ticket creation, carrying the customer + Chatwoot conversation.</summary>
    private void CreateTicketFor(Guid customerId)
    {
        var url = $"/tickets/new?customerId={customerId}";
        if (!string.IsNullOrEmpty(CwContext.ConversationId))
        {
            url += $"&conversationId={Uri.EscapeDataString(CwContext.ConversationId)}";
        }
        Nav.NavigateTo(url);
    }

    private void GoTo(Guid id) => Nav.NavigateTo($"/customers/{id}");

    // Debounce guard for instant (as-you-type) search.
    private CancellationTokenSource? _debounceCts;
    private const int DebounceMs = 300;

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _term = e.Value?.ToString() ?? string.Empty;
        _page = 1;

        // Cancel any pending debounced search and start a fresh window.
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(DebounceMs, token);
            if (!token.IsCancellationRequested)
            {
                await SearchAsync();
            }
        }
        catch (TaskCanceledException)
        {
            // A newer keystroke superseded this one — ignore.
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Enter fires an immediate search, cancelling any pending debounce.
            _debounceCts?.Cancel();
            _page = 1;
            await SearchAsync();
        }
    }

    private async Task SearchAsync()
    {
        var term = _term.Trim();

        // Empty term => load the full directory (auto-load / cleared search box).
        // Otherwise require at least 2 characters to avoid noisy single-char queries.
        if (term.Length is 1)
        {
            Toasts.Info(T("Cust.MinChars"));
            return;
        }

        _loading = true;
        _lastTerm = term;
        try
        {
            var result = await Api.SearchCustomersAsync(term, _page, 9);
            _results = result.Customers;
            _totalPages = Math.Max(result.TotalPages, 1);
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message);
            _results = [];
        }
        catch (HttpRequestException)
        {
            Toasts.Error(T("Common.CannotReachApi"));
            _results = [];
        }
        finally
        {
            _loading = false;
        }
    }

    /* ================= Bulk import (Excel) ================= */

    private void OpenImport()
    {
        _importResult = null;
        _importFileName = null;
        _importStream = null;
        _showImport = true;
    }

    private async Task DownloadTemplateAsync()
    {
        _downloadingTemplate = true;
        try
        {
            var (content, fileName) = await Api.DownloadImportTemplateAsync();
            await JS.InvokeVoidAsync(
                "unigroup.downloadFile",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(content));
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        catch (HttpRequestException) { Toasts.Error(T("Common.CannotReachApi")); }
        finally { _downloadingTemplate = false; }
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        _importResult = null;
        var file = e.File;
        if (file is null) return;

        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            Toasts.Error(T("Cust.ImportBadType"));
            _importFileName = null;
            _importStream = null;
            return;
        }

        // Buffer the file into memory (max 10 MB) so it can be re-read on submit.
        var buffer = new System.IO.MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(buffer);
        buffer.Position = 0;
        _importStream = buffer;
        _importFileName = file.Name;
    }

    private async Task ImportAsync()
    {
        if (_importStream is null) return;
        _importing = true;
        _importResult = null;
        try
        {
            _importStream.Position = 0;
            _importResult = await Api.ImportCustomersAsync(_importStream, _importFileName ?? "import.xlsx");

            if (_importResult.SuccessCount > 0)
            {
                Toasts.Success(T("Cust.ImportResult", _importResult.SuccessCount, _importResult.FailedCount));
                // Refresh the current search results so imported customers appear.
                if (!string.IsNullOrWhiteSpace(_lastTerm))
                {
                    try
                    {
                        var result = await Api.SearchCustomersAsync(_lastTerm, _page, 9);
                        _results = result.Customers;
                        _totalPages = Math.Max(result.TotalPages, 1);
                    }
                    catch { /* non-fatal */ }
                }
            }
            else
            {
                Toasts.Info(T("Cust.ImportResult", _importResult.SuccessCount, _importResult.FailedCount));
            }
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        catch (HttpRequestException) { Toasts.Error(T("Common.CannotReachApi")); }
        finally { _importing = false; }
    }

    private async Task CreateAsync()
    {
        _creating = true;
        try
        {
            var id = await Api.CreateCustomerAsync(new CreateCustomerRequest(
                _create.Name.Trim(),
                string.IsNullOrWhiteSpace(_create.Email) ? null : _create.Email.Trim(),
                _create.Province, _create.City, _create.AddressDetails,
                _create.Phone.Trim(),
                string.IsNullOrWhiteSpace(_create.CustomerGroup) ? null : _create.CustomerGroup.Trim()));

            Toasts.Success(T("Cust.Created"));
            _showCreate = false;
            _create = new CreateModel();

            // Inside Chatwoot, keep the agent in the conversation flow by going
            // straight to ticket creation with the new customer + conversation.
            if (Embedded.IsEmbedded && !string.IsNullOrEmpty(CwContext.ConversationId))
            {
                CreateTicketFor(id);
            }
            else
            {
                Nav.NavigateTo($"/customers/{id}");
            }
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message);
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await SearchAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await SearchAsync(); } }

    public override void Dispose()
    {
        if (Embedded.IsEmbedded)
        {
            CwContext.OnContextChanged -= OnCwContextChanged;
        }
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        base.Dispose();
    }
}
