@page "/tickets/{TicketId}"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts
@inject JwtAuthenticationStateProvider Auth
@inject IJSRuntime JS

<PageTitle>@(_ticket?.Id ?? T("TkD.Ticket")) — UniGroup CRM</PageTitle>

<div class="page-pad anim-fade-up">
    @if (_loading)
    {
        <Skeleton Height="90px" Style="margin-bottom:16px" />
        <div class="grid" style="grid-template-columns:2fr 1fr;gap:16px">
            <Skeleton Height="300px" />
            <Skeleton Height="300px" />
        </div>
    }
    else if (_ticket is null)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-ticket-perforated"></i></div>
            <h3>@T("TkD.NotFoundTitle")</h3>
            <p>@T("TkD.NotFoundText", TicketId)</p>
            <button class="btn btn-primary" @onclick="GoToList"><i class="bi bi-arrow-left flip-rtl"></i> @T("TkC.Back")</button>
        </div>
    }
    else
    {
        <!-- ══════════ HEADER ══════════ -->
        <div class="card glass" style="padding:22px 24px;margin-bottom:16px">
            <div class="spread wrap" style="gap:14px">
                <div style="min-width:0">
                    <div class="row wrap" style="gap:8px;margin-bottom:6px">
                        <span class="mono muted" style="font-size:12.5px">@_ticket.Id</span>
                        <span class="badge @UiHelpers.StatusBadge(_ticket.Status)">@TStatus(_ticket.Status)</span>
                        <span class="badge @UiHelpers.PriorityBadge(_ticket.Priority)">@TPriority(_ticket.Priority)</span>
                        <span class="badge badge-purple" title="@T("TkC.MainCategory")"><i class="bi bi-diagram-3"></i> @TMainCategory(_ticket.MainCategoryName)</span>
                        <span class="badge badge-slate" title="@T("TkC.SubCategory")"><i class="bi @CategoryIconClass"></i> @CategoryLabelText</span>
                    </div>
                    <h1 style="font-size:20px;margin:0">@_ticket.Title</h1>
                    <div class="subtle" style="margin-top:6px">
                        @T("TkD.CreatedAt", TimeAgo(_ticket.CreatedAt)) · @T("TkD.UpdatedAt", TimeAgo(_ticket.UpdatedAt))
                        @if (_ticket.ClosedAt is { } closed)
                        {
                            <text> · @T("TkD.ClosedAt", TimeAgo(closed))</text>
                        }
                    </div>
                </div>
                <div style="text-align:end">
                    <div class="subtle" style="margin-bottom:4px">@T("TkD.SlaCountdown")</div>
                    <div style="font-size:18px">
                        <SlaTimer Deadline="@_ticket.SlaDeadline" Breached="@_ticket.SlaBreached"
                                  Status="@_ticket.Status" TotalHours="@SlaTotalHours" />
                    </div>
                    @if (UiHelpers.IsSlaPaused(_ticket.Status))
                    {
                        <div class="subtle" style="margin-top:4px"><i class="bi bi-pause-circle"></i> @T("TkD.SlaPausedNote")</div>
                    }
                </div>
            </div>
        </div>

        <div class="grid" style="grid-template-columns:minmax(0,2fr) minmax(0,1fr);gap:16px;align-items:start">
            <!-- ══════════ LEFT: description / notes / attachments / history ══════════ -->
            <div class="grid" style="gap:16px">

                <!-- Description -->
                <div class="card" style="padding:20px">
                    <div class="section-title" style="margin-bottom:10px"><i class="bi bi-card-text"></i> @T("TkD.Description")</div>
                    <p style="white-space:pre-wrap;margin:0;font-size:13.5px;line-height:1.65">@_ticket.Description</p>
                    @if (!string.IsNullOrWhiteSpace(_ticket.ResolutionNote))
                    {
                        <div class="card resolution-note" style="margin-top:14px;padding:14px">
                            <div style="font-weight:700;font-size:12.5px;margin-bottom:6px"><i class="bi bi-check-circle-fill"></i> @T("TkD.Resolution")</div>
                            <p style="white-space:pre-wrap;margin:0;font-size:13px">@_ticket.ResolutionNote</p>
                        </div>
                    }
                </div>

                <!-- Tabs: Notes / Attachments / History -->
                <div class="card" style="padding:0;overflow:hidden">
                    <div class="tabs" style="padding:0 16px;border-bottom:1px solid var(--border)">
                        <button class="tab @(_tab == "notes" ? "active" : "")" @onclick="ShowNotes"><i class="bi bi-chat-dots"></i> @T("TkD.Notes") (@_ticket.InternalNotes.Count)</button>
                        <button class="tab @(_tab == "files" ? "active" : "")" @onclick="ShowFiles"><i class="bi bi-paperclip"></i> @T("TkD.Attachments") (@_ticket.Attachments.Count)</button>
                        <button class="tab @(_tab == "history" ? "active" : "")" @onclick="ShowHistory"><i class="bi bi-clock-history"></i> @T("TkD.History") (@_ticket.Histories.Count)</button>
                    </div>

                    <div style="padding:18px 20px">
                        @if (_tab == "notes")
                        {
                            @if (_ticket.InternalNotes.Count == 0)
                            {
                                <p class="subtle" style="margin:0 0 14px">@T("TkD.NoNotes")</p>
                            }
                            else
                            {
                                <div class="grid" style="gap:12px;margin-bottom:16px" id="notes-thread">
                                    @foreach (var note in _ticket.InternalNotes.OrderBy(n => n.CreatedAt))
                                    {
                                        <div class="row" style="align-items:flex-start;gap:10px">
                                            <div class="avatar" style="flex-shrink:0">@UiHelpers.Initials(note.AuthorName)</div>
                                            <div class="card" style="flex:1;padding:12px 14px">
                                                <div class="spread" style="margin-bottom:5px">
                                                    <span style="font-weight:700;font-size:12.5px">@note.AuthorName</span>
                                                    <span class="subtle">@TimeAgo(note.CreatedAt)@(note.IsEdited ? $" · {T("TkD.Edited")}" : "")</span>
                                                </div>
                                                <p style="white-space:pre-wrap;margin:0;font-size:13px;line-height:1.55">@note.Content</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="field" style="margin-bottom:8px">
                                <textarea class="textarea" rows="3" placeholder="@T("TkD.NotePlaceholder")"
                                          @bind="_newNote" @bind:event="oninput"></textarea>
                            </div>
                            <div class="row" style="justify-content:flex-end">
                                <button class="btn btn-primary btn-sm" @onclick="AddNoteAsync"
                                        disabled="@(string.IsNullOrWhiteSpace(_newNote) || _savingNote)">
                                    @(_savingNote ? T("TkD.Posting") : T("TkD.PostNote"))
                                </button>
                            </div>
                        }
                        else if (_tab == "files")
                        {
                            @if (_ticket.Attachments.Count == 0)
                            {
                                <p class="subtle" style="margin:0 0 14px">@T("TkD.NoAttachments")</p>
                            }
                            else
                            {
                                <div class="grid" style="gap:8px;margin-bottom:16px">
                                    @foreach (var file in _ticket.Attachments.OrderByDescending(a => a.CreatedAt))
                                    {
                                        <div class="card row spread" style="padding:10px 14px">
                                            <div class="row" style="min-width:0">
                                                <span style="font-size:18px"><i class="bi @FileIcon(file.ContentType)"></i></span>
                                                <div style="min-width:0">
                                                    <div style="font-weight:600;font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@file.FileName</div>
                                                    <div class="subtle">@UiHelpers.FormatBytes(file.FileSizeBytes) · @T("TkD.By", file.UploadedByName) · @TimeAgo(file.CreatedAt)</div>
                                                </div>
                                            </div>
                                            <a class="btn btn-ghost btn-sm" href="@FileHref(file)" target="_blank" rel="noopener">@T("Common.Open")</a>
                                        </div>
                                    }
                                </div>
                            }
                            <label class="btn btn-secondary btn-sm" style="position:relative;overflow:hidden;cursor:pointer">
                                @if (_uploading)
                                {
                                    @T("TkD.Uploading")
                                }
                                else
                                {
                                    <i class="bi bi-paperclip"></i> @T("TkD.UploadFile")
                                }
                                <InputFile OnChange="UploadAsync" disabled="@_uploading"
                                           style="position:absolute;inset:0;opacity:0;cursor:pointer" />
                            </label>
                        }
                        else
                        {
                            @if (_ticket.Histories.Count == 0)
                            {
                                <p class="subtle" style="margin:0">@T("TkD.NoHistory")</p>
                            }
                            else
                            {
                                <div class="timeline">
                                    @foreach (var h in _ticket.Histories.OrderByDescending(x => x.CreatedAt))
                                    {
                                        <div class="timeline-item">
                                            <div class="row wrap" style="gap:8px;margin-bottom:3px">
                                                @if (h.FromStatus is not null)
                                                {
                                                    <span class="badge @UiHelpers.StatusBadge(h.FromStatus)">@TStatus(h.FromStatus)</span>
                                                    <span class="muted"><i class="bi bi-arrow-right flip-rtl"></i></span>
                                                }
                                                <span class="badge @UiHelpers.StatusBadge(h.ToStatus)">@TStatus(h.ToStatus)</span>
                                            </div>
                                            <div class="subtle">
                                                @T("TkD.By", h.ChangedByName) · @TimeAgo(h.CreatedAt)
                                                @if (h.TimeInStatus is { } secs and > 0)
                                                {
                                                    <text> · @T("TkD.InPreviousStatus", UiHelpers.FormatDuration((int)secs))</text>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(h.Note))
                                            {
                                                <div style="font-size:12.5px;margin-top:4px">“@h.Note”</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- ══════════ RIGHT: customer / device / assignment / transitions ══════════ -->
            <div class="grid" style="gap:16px">

                <!-- Customer card -->
                <div class="card hoverable" style="padding:16px;cursor:pointer" @onclick="GoToCustomer">
                    <div class="section-title" style="margin-bottom:10px"><i class="bi bi-person"></i> @T("TkD.Customer")</div>
                    <div class="row">
                        <div class="avatar">@UiHelpers.Initials(_ticket.CustomerName)</div>
                        <div style="min-width:0">
                            <div style="font-weight:700;font-size:13.5px">@_ticket.CustomerName</div>
                            <div class="subtle mono">@(_ticket.CustomerPhone ?? "—")</div>
                            @if (!string.IsNullOrEmpty(_ticket.CustomerEmail))
                            {
                                <div class="subtle">@_ticket.CustomerEmail</div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Device card -->
                @if (_ticket.CustomerDeviceId is not null)
                {
                    <div class="card" style="padding:16px">
                        <div class="section-title" style="margin-bottom:10px"><i class="bi bi-phone"></i> @T("TkD.Device")</div>
                        <div style="font-weight:700;font-size:13.5px">@_ticket.CustomerDeviceBrandName @_ticket.CustomerDeviceModelName</div>
                        @if (!string.IsNullOrEmpty(_ticket.CustomerDeviceIMEI))
                        {
                            <div class="subtle mono">IMEI @_ticket.CustomerDeviceIMEI</div>
                        }
                        @if (!string.IsNullOrEmpty(_ticket.CustomerDeviceSerialNumber))
                        {
                            <div class="subtle mono">S/N @_ticket.CustomerDeviceSerialNumber</div>
                        }
                    </div>
                }

                <!-- Assignment -->
                <div class="card" style="padding:16px">
                    <div class="section-title" style="margin-bottom:10px"><i class="bi bi-compass"></i> @T("TkD.Assignment")</div>
                    <div class="field">
                        <label>@T("TkD.AssignedAgent")</label>
                        <div style="font-size:13px;font-weight:600">@(_ticket.AssignedToName ?? T("TkD.Unassigned"))</div>
                    </div>
                    <div class="field">
                        <label>@T("TkD.Department")</label>
                        <select class="select" @onchange="OnDeptSelected" disabled="@(_assigning || IsTicketTerminal)">
                            <option value="" selected="@(_ticket.DepartmentId is null)">@T("TkD.None")</option>
                            @foreach (var d in _departments)
                            {
                                <option value="@d.Id" selected="@(_ticket.DepartmentId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row wrap" style="gap:8px">
                        <button class="btn btn-secondary btn-sm" @onclick="AssignToMeAsync"
                                disabled="@(_assigning || IsTicketTerminal || IsAssignedToMe)">
                            @if (IsAssignedToMe)
                            {
                                <i class="bi bi-check-lg"></i> @T("TkD.AssignedToYou")
                            }
                            else
                            {
                                <i class="bi bi-person-plus"></i> @T("TkD.AssignToMe")
                            }
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="SaveAssignmentAsync"
                                disabled="@(_assigning || IsTicketTerminal || !_deptDirty)">
                            @(_assigning ? T("Common.Saving") : T("TkD.SaveDepartment"))
                        </button>
                    </div>
                </div>

                <!-- Status transition -->
                <div class="card" style="padding:16px">
                    <div class="section-title" style="margin-bottom:10px"><i class="bi bi-arrow-repeat"></i> @T("TkD.ChangeStatus")</div>
                    @if (NextOptions.Count == 0)
                    {
                        <p class="subtle" style="margin:0">@T("TkD.TerminalNote")</p>
                    }
                    else
                    {
                        <div class="field">
                            <label>@T("TkD.NewStatus")</label>
                            <select class="select" @onchange="OnStatusSelected" disabled="@_transitioning">
                                <option value="">@T("TkD.Choose")</option>
                                @foreach (var s in NextOptions)
                                {
                                    <option value="@((int)s)" selected="@(_targetStatus == s)">@TStatus(s.ToString())</option>
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label>@T("TkD.Note") @(RequiresNote ? T("TkD.NoteRequired") : T("TkD.NoteOptional"))</label>
                            <textarea class="textarea" rows="2"
                                      placeholder="@(RequiresNote ? T("TkD.NoteRequiredPlaceholder") : T("TkD.NoteWhy"))"
                                      @bind="_transitionNote" @bind:event="oninput"></textarea>
                        </div>
                        <button class="btn btn-primary" style="width:100%"
                                @onclick="TransitionAsync"
                                disabled="@(_transitioning || _targetStatus is null || (RequiresNote && string.IsNullOrWhiteSpace(_transitionNote)))">
                            @(_transitioning ? T("TkD.Applying") : T("TkD.ApplyTransition"))
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string TicketId { get; set; } = string.Empty;

    private TicketDetailsDto? _ticket;
    private List<DepartmentDto> _departments = [];
    private bool _loading = true;

    private string _tab = "notes";

    private string _newNote = string.Empty;
    private bool _savingNote;

    private bool _uploading;

    private Guid? _selectedDeptId;
    private bool _deptDirty;
    private bool _assigning;

    private TicketStatus? _targetStatus;
    private string _transitionNote = string.Empty;
    private bool _transitioning;

    private bool IsTicketTerminal => _ticket is not null && UiHelpers.IsTerminal(_ticket.Status);

    private List<TicketStatus> NextOptions =>
        _ticket is null ? [] : UiHelpers.NextStatuses(_ticket.Status).ToList();

    private bool RequiresNote =>
        _targetStatus is TicketStatus.Resolved or TicketStatus.Cancelled;

    private bool IsAssignedToMe =>
        _ticket?.AssignedToId is { } id && string.Equals(id.ToString(), Auth.Session?.UserId, StringComparison.OrdinalIgnoreCase);

    private string CategoryIconClass =>
        _ticket is not null && Enum.TryParse<TicketCategory>(_ticket.Category, out var cat)
            ? UiHelpers.CategoryIcon(cat)
            : "bi-tag";

    private string CategoryLabelText =>
        _ticket is null ? string.Empty : TCategory(_ticket.Category);

    private double SlaTotalHours =>
        _ticket is not null && Enum.TryParse<TicketPriority>(_ticket.Priority, out var pr)
            ? UiHelpers.SlaHours[pr]
            : 24;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var ticketTask = Api.GetTicketAsync(TicketId);
            if (_departments.Count == 0)
            {
                try { _departments = await Api.GetDepartmentsAsync(); } catch { /* non-fatal */ }
            }
            _ticket = await ticketTask;
            _selectedDeptId = _ticket.DepartmentId;
            _deptDirty = false;
            _targetStatus = null;
            _transitionNote = string.Empty;
        }
        catch (ApiException)
        {
            _ticket = null;
        }
        finally { _loading = false; }
    }

    // ───── tabs ─────
    private void ShowNotes() => _tab = "notes";
    private void ShowFiles() => _tab = "files";
    private void ShowHistory() => _tab = "history";

    // ───── notes ─────
    private async Task AddNoteAsync()
    {
        if (string.IsNullOrWhiteSpace(_newNote) || _ticket is null) return;
        _savingNote = true;
        try
        {
            await Api.AddInternalNoteAsync(_ticket.Id, new AddInternalNoteRequest(_newNote.Trim()));
            _newNote = string.Empty;
            Toasts.Success(T("TkD.NoteAdded"));
            await LoadAsync();
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _savingNote = false; }
    }

    // ───── attachments ─────
    private async Task UploadAsync(InputFileChangeEventArgs e)
    {
        if (_ticket is null) return;
        var file = e.File;
        const long maxBytes = 10 * 1024 * 1024;
        if (file.Size > maxBytes)
        {
            Toasts.Error(T("TkD.FileTooLarge", UiHelpers.FormatBytes(file.Size)));
            return;
        }
        _uploading = true;
        try
        {
            await using var stream = file.OpenReadStream(maxBytes);
            await Api.UploadAttachmentAsync(_ticket.Id, stream, file.Name,
                string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType);
            Toasts.Success(T("TkD.Uploaded", file.Name));
            await LoadAsync();
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _uploading = false; }
    }

    private static string FileIcon(string contentType) => contentType switch
    {
        var t when t.StartsWith("image/") => "bi-file-earmark-image",
        var t when t.StartsWith("video/") => "bi-file-earmark-play",
        var t when t.StartsWith("audio/") => "bi-file-earmark-music",
        "application/pdf" => "bi-file-earmark-pdf",
        _ => "bi-file-earmark-text",
    };

    private string FileHref(AttachmentDto file) =>
        file.StorageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? file.StorageUrl
            : $"{Api.BaseUrl.TrimEnd('/')}/{file.StorageUrl.TrimStart('/')}";

    // ───── assignment ─────
    private void OnDeptSelected(ChangeEventArgs e)
    {
        _selectedDeptId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null;
        _deptDirty = _selectedDeptId != _ticket?.DepartmentId;
    }

    private async Task SaveAssignmentAsync()
    {
        if (_ticket is null) return;
        _assigning = true;
        try
        {
            await Api.AssignTicketAsync(_ticket.Id,
                new AssignTicketRequest(_ticket.AssignedToId, _selectedDeptId, "Department updated"));
            Toasts.Success(T("TkD.DeptUpdated"));
            await LoadAsync();
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _assigning = false; }
    }

    private async Task AssignToMeAsync()
    {
        if (_ticket is null || Auth.Session is not { } session) return;
        if (!Guid.TryParse(session.UserId, out var myId))
        {
            Toasts.Error(T("TkD.UserIdError"));
            return;
        }
        _assigning = true;
        try
        {
            await Api.AssignTicketAsync(_ticket.Id,
                new AssignTicketRequest(myId, _ticket.DepartmentId, "Self-assigned"));
            Toasts.Success(T("TkD.TicketAssigned"));
            await LoadAsync();
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _assigning = false; }
    }

    // ───── status transition ─────
    private void OnStatusSelected(ChangeEventArgs e) =>
        _targetStatus = int.TryParse(e.Value?.ToString(), out var v) ? (TicketStatus)v : null;

    private async Task TransitionAsync()
    {
        if (_ticket is null || _targetStatus is not { } target) return;
        if (RequiresNote && string.IsNullOrWhiteSpace(_transitionNote)) return;
        _transitioning = true;
        try
        {
            await Api.TransitionTicketStatusAsync(_ticket.Id,
                new TransitionStatusRequest(target, string.IsNullOrWhiteSpace(_transitionNote) ? null : _transitionNote.Trim()));
            Toasts.Success(T("TkD.StatusChanged", TStatus(target.ToString())));
            await LoadAsync();
        }
        catch (ApiException ex) { Toasts.Error(ex.Message); }
        finally { _transitioning = false; }
    }

    // ───── navigation ─────
    private void GoToList() => Nav.NavigateTo("/tickets");
    private void GoToCustomer()
    {
        if (_ticket is not null) Nav.NavigateTo($"/customers/{_ticket.CustomerId}");
    }
}
