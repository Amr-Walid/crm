@page "/register"
@layout EmptyLayout
@inject CrmApiClient Api
@inject JwtAuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>Create account — UniGroup CRM</PageTitle>

<div class="auth-page">
    <div class="auth-orb" style="width:420px;height:420px;background:#8b5cf6;top:-120px;left:-80px"></div>
    <div class="auth-orb" style="width:360px;height:360px;background:#0ea5e9;bottom:-120px;right:-80px"></div>

    <div class="glass auth-card anim-scale-in">
        <div class="auth-logo">
            <div class="mark">U</div>
            <h2 style="font-size:21px">Create your account</h2>
            <p class="muted" style="margin:0;font-size:13px">Join the UniGroup CRM workspace</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <div class="row" style="align-items:flex-start">
                <div class="field" style="flex:1">
                    <label>First name</label>
                    <InputText class="input" @bind-Value="_model.FirstName" placeholder="Ahmed" />
                    <ValidationMessage For="() => _model.FirstName" />
                </div>
                <div class="field" style="flex:1">
                    <label>Last name</label>
                    <InputText class="input" @bind-Value="_model.LastName" placeholder="Walid" />
                    <ValidationMessage For="() => _model.LastName" />
                </div>
            </div>
            <div class="field">
                <label>Email address</label>
                <InputText class="input" @bind-Value="_model.Email" placeholder="agent@unigroup.com" autocomplete="username" />
                <ValidationMessage For="() => _model.Email" />
            </div>
            <div class="field">
                <label>Password</label>
                <InputText class="input" @bind-Value="_model.Password" type="password" placeholder="Min 8 chars, upper, lower, digit, symbol" autocomplete="new-password" />
                <ValidationMessage For="() => _model.Password" />
            </div>

            @if (_error is not null)
            {
                <div style="color:var(--danger);font-size:12.5px;margin-bottom:12px">@_error</div>
            }

            <button class="btn btn-primary btn-lg" style="width:100%" type="submit" disabled="@_busy">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>Creating account…</span>
                }
                else
                {
                    <span>Create account</span>
                }
            </button>
        </EditForm>

        <p style="text-align:center;margin:18px 0 0;font-size:13px" class="muted">
            Already registered? <a href="/login">Sign in</a>
        </p>
    </div>
</div>

@code {
    private sealed class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "First name is required")]
        public string FirstName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Last name is required")]
        public string LastName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Minimum 8 characters")]
        public string Password { get; set; } = string.Empty;
    }

    private readonly RegisterModel _model = new();
    private bool _busy;
    private string? _error;

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var response = await Api.RegisterAsync(new RegisterRequest(
                _model.Email.Trim(), _model.Password, _model.FirstName.Trim(), _model.LastName.Trim()));
            await Auth.SignInAsync(response);
            Toasts.Success($"Welcome aboard, {response.FirstName}!");
            Nav.NavigateTo("/");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException)
        {
            _error = "Cannot reach the API server. Is the backend running on the configured URL?";
        }
        finally
        {
            _busy = false;
        }
    }
}
