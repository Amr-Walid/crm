@page "/register"
@layout EmptyLayout
@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject JwtAuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject ToastService Toasts

<PageTitle>@T("Register.PageTitle")</PageTitle>

<div class="auth-page">
    <div class="auth-orb" style="width:420px;height:420px;background:#8b5cf6;top:-120px;left:-80px"></div>
    <div class="auth-orb" style="width:360px;height:360px;background:#0ea5e9;bottom:-120px;right:-80px"></div>

    <div class="glass auth-card anim-scale-in">
        <div class="auth-logo">
            <div class="mark">U</div>
            <h2 style="font-size:21px">@T("Register.Title")</h2>
            <p class="muted" style="margin:0;font-size:13px">@T("Register.Subtitle")</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <div class="row" style="align-items:flex-start">
                <div class="field" style="flex:1">
                    <label>@T("Register.FirstName")</label>
                    <InputText class="input" @bind-Value="_model.FirstName" placeholder="Ahmed" />
                    <LocalizedValidationMessage For="() => _model.FirstName" />
                </div>
                <div class="field" style="flex:1">
                    <label>@T("Register.LastName")</label>
                    <InputText class="input" @bind-Value="_model.LastName" placeholder="Walid" />
                    <LocalizedValidationMessage For="() => _model.LastName" />
                </div>
            </div>
            <div class="field">
                <label>@T("Login.Email")</label>
                <InputText class="input" @bind-Value="_model.Email" placeholder="agent@unigroup.com" autocomplete="username" />
                <LocalizedValidationMessage For="() => _model.Email" />
            </div>
            <div class="field">
                <label>@T("Login.Password")</label>
                <InputText class="input" @bind-Value="_model.Password" type="password" placeholder="Min 8 chars, upper, lower, digit, symbol" autocomplete="new-password" />
                <LocalizedValidationMessage For="() => _model.Password" />
            </div>

            @if (_error is not null)
            {
                <div style="color:var(--danger);font-size:12.5px;margin-bottom:12px">@_error</div>
            }

            <button class="btn btn-primary btn-lg" style="width:100%" type="submit" disabled="@_busy">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>@T("Register.CreatingAccount")</span>
                }
                else
                {
                    <span>@T("Register.CreateAccount")</span>
                }
            </button>
        </EditForm>

        <p style="text-align:center;margin:18px 0 0;font-size:13px" class="muted">
            @T("Register.AlreadyRegistered") <a href="/login">@T("Login.SignIn")</a>
        </p>
    </div>
</div>

@code {
    private sealed class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.FirstNameRequired")]
        public string FirstName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.LastNameRequired")]
        public string LastName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.EmailRequired")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Validation.EmailInvalid")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Validation.PasswordRequired")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Validation.PasswordMin")]
        public string Password { get; set; } = string.Empty;
    }

    private readonly RegisterModel _model = new();
    private bool _busy;
    private string? _error;

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var response = await Api.RegisterAsync(new RegisterRequest(
                _model.Email.Trim(), _model.Password, _model.FirstName.Trim(), _model.LastName.Trim()));
            await Auth.SignInAsync(response);
            Toasts.Success(T("Register.WelcomeAboard", response.FirstName));
            Nav.NavigateTo("/");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (HttpRequestException)
        {
            _error = T("Common.CannotReachApiBackend");
        }
        finally
        {
            _busy = false;
        }
    }
}
