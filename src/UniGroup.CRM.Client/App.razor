<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
                <Authorizing>
                    <div class="boot-loader">
                        <div class="boot-mark">U</div>
                        <div class="boot-title">UniGroup <span>CRM</span></div>
                        <div class="boot-bar"><div class="boot-bar-fill"></div></div>
                        <div class="boot-sub">Restoring session…</div>
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found — UniGroup CRM</PageTitle>
            <LayoutView Layout="@typeof(EmptyLayout)">
                <div class="auth-page">
                    <div class="glass auth-card" style="text-align:center">
                        <div class="empty-state">
                            <div class="icon">🧭</div>
                            <h2>Page not found</h2>
                            <p class="muted">The page you are looking for does not exist.</p>
                            <a class="btn btn-primary" href="/">Back to home</a>
                        </div>
                    </div>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
