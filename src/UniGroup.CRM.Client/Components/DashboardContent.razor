@inherits LocalizedComponentBase
@inject CrmApiClient Api
@inject NavigationManager Nav
@inject ToastService Toasts

<div class="page-pad anim-fade-up">
    <div class="spread wrap" style="margin-bottom:20px;gap:12px">
        <div>
            <h1 style="font-size:22px">@T("Dash.Title")</h1>
            <p class="muted" style="margin:4px 0 0">@T("Dash.Subtitle")</p>
        </div>
        <div class="row" style="gap:8px">
            <input type="date" class="input" style="width:170px" value="@_date.ToString("yyyy-MM-dd")" @onchange="OnDateChanged" />
            <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_loading">
                @if (_loading)
                {
                    @T("Common.Loading")
                }
                else
                {
                    <i class="bi bi-arrow-clockwise"></i> @T("Dash.Refresh")
                }
            </button>
        </div>
    </div>

    @if (_loading && _summary is null)
    {
        <div class="stat-grid" style="margin-bottom:16px">
            @for (var i = 0; i < 4; i++) { <Skeleton Height="92px" /> }
        </div>
        <div class="grid" style="grid-template-columns:1fr 1fr;gap:16px">
            <Skeleton Height="240px" /><Skeleton Height="240px" />
        </div>
    }
    else if (_summary is null)
    {
        <div class="card empty-state">
            <div class="icon"><i class="bi bi-speedometer2"></i></div>
            <h3>@T("Dash.Unavailable")</h3>
            <p>@(_error ?? T("Dash.CouldNotLoad"))</p>
            <button class="btn btn-primary" @onclick="RefreshAsync">@T("Common.Retry")</button>
        </div>
    }
    else
    {
        <!-- ═══════ METRIC CARDS ═══════ -->
        <div class="stat-grid" style="margin-bottom:16px">
            <div class="card stat-card">
                <div class="stat-label">@T("Dash.NewToday")</div>
                <div class="stat-value">@_summary.TodayNewTickets</div>
                <div class="stat-sub">@T("Dash.TopIssue", _summary.TopIssueCategory ?? "—")</div>
                <div class="stat-icon" style="background:rgba(99,102,241,.15)"><i class="bi bi-ticket-perforated"></i></div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">@T("Dash.OpenTickets")</div>
                <div class="stat-value">@_summary.OpenTicketsTotal</div>
                <div class="stat-sub">@T("Dash.AcrossDepts")</div>
                <div class="stat-icon" style="background:rgba(59,130,246,.15)"><i class="bi bi-folder2-open"></i></div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">@T("Dash.SlaBreached")</div>
                <div class="stat-value" style="color:@(_summary.BreachedSlaCount > 0 ? "var(--danger)" : "inherit")">@_summary.BreachedSlaCount</div>
                <div class="stat-sub">@T("Dash.Compliance", _summary.SlaComplianceRate.ToString("0.#"))</div>
                <div class="stat-icon" style="background:rgba(239,68,68,.15)"><i class="bi bi-alarm"></i></div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">@T("Dash.AvgResolution")</div>
                <div class="stat-value">@(_summary.AvgResolutionTimeToday.ToString("0.#"))h</div>
                <div class="stat-sub">@T("Dash.CallsLogged", _summary.CallsLoggedToday)</div>
                <div class="stat-icon" style="background:rgba(16,185,129,.15)"><i class="bi bi-lightning-charge"></i></div>
            </div>
        </div>

        <div class="grid" style="grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:16px;margin-bottom:16px">
            <!-- ═══════ TICKETS BY STATUS ═══════ -->
            <div class="card" style="padding:20px">
                <div class="section-title" style="margin-bottom:12px"><i class="bi bi-kanban"></i> @T("Dash.ByStatus")</div>
                @if (_byStatus.Count == 0)
                {
                    <p class="subtle" style="margin:0">@T("Dash.NoTicketData")</p>
                }
                else
                {
                    var max = Math.Max(_byStatus.Values.Max(), 1);
                    @foreach (var kv in _byStatus.OrderByDescending(k => k.Value))
                    {
                        <div class="bar-row">
                            <div class="bar-label">@TStatus(kv.Key)</div>
                            <div class="bar-track">
                                <div class="bar-fill" style="width:@(Math.Max(kv.Value * 100.0 / max, 6).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%">@kv.Value</div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- ═══════ HOURLY CALL VOLUME ═══════ -->
            <div class="card" style="padding:20px">
                <div class="section-title" style="margin-bottom:12px"><i class="bi bi-telephone"></i> @T("Dash.CallVolume", _date.ToString("dd MMM"))</div>
                @if (_calls.Count == 0 || _calls.All(c => c.CallCount == 0))
                {
                    <p class="subtle" style="margin:0">@T("Dash.NoCalls")</p>
                }
                else
                {
                    var maxCalls = Math.Max(_calls.Max(c => c.CallCount), 1);
                    <div class="spark-cols">
                        @foreach (var h in _calls.OrderBy(c => c.Hour))
                        {
                            <div class="spark-col" style="height:@(Math.Max(h.CallCount * 100.0 / maxCalls, 2).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%">
                                <span class="tip">@T("Dash.CallsTip", h.Hour, h.CallCount, UiHelpers.FormatDuration((int)h.AvgDurationSeconds))</span>
                            </div>
                        }
                    </div>
                    <div class="spark-x">
                        @foreach (var h in _calls.OrderBy(c => c.Hour))
                        {
                            <span>@(h.Hour % 4 == 0 ? h.Hour.ToString("00") : "")</span>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ═══════ AGENT PERFORMANCE GRID ═══════ -->
        <div class="card" style="padding:20px;margin-bottom:16px">
            <div class="spread" style="margin-bottom:12px">
                <div class="section-title"><i class="bi bi-person-badge"></i> @T("Dash.AgentPerf")</div>
            </div>
            @if (_agents.Count == 0)
            {
                <p class="subtle" style="margin:0">@T("Dash.NoAgentActivity")</p>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>@T("Dash.ColAgent")</th>
                                <th style="text-align:end">@T("Dash.ColHandled")</th>
                                <th style="text-align:end">@T("Dash.ColOpen")</th>
                                <th style="text-align:end">@T("Dash.ColAvgRes")</th>
                                <th style="text-align:end">@T("Dash.ColSla")</th>
                                <th style="text-align:end">@T("Dash.ColCsat")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _agents.OrderByDescending(x => x.TotalTicketsHandled))
                            {
                                <tr>
                                    <td>
                                        <div class="row">
                                            <div class="avatar" style="width:30px;height:30px;font-size:11px">@UiHelpers.Initials(a.AgentName)</div>
                                            <span style="font-weight:600">@a.AgentName</span>
                                        </div>
                                    </td>
                                    <td style="text-align:end" class="mono">@a.TotalTicketsHandled</td>
                                    <td style="text-align:end" class="mono">@a.OpenTicketsCount</td>
                                    <td style="text-align:end" class="mono">@(a.AvgResolutionTimeHours.ToString("0.#"))h</td>
                                    <td style="text-align:end">
                                        <span class="badge @SlaBadge(a.SlaComplianceRate)">@(a.SlaComplianceRate.ToString("0.#"))%</span>
                                    </td>
                                    <td style="text-align:end">
                                        @if (a.CsatAvgScore is { } cs)
                                        {
                                            <i class="bi bi-star-fill" style="color:#f59e0b;font-size:11px"></i> @cs.ToString("0.0")
                                        }
                                        else
                                        {
                                            <text>—</text>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- ═══════ DEVICE FAILURE BREAKDOWN ═══════ -->
        <div class="card" style="padding:20px">
            <div class="section-title" style="margin-bottom:12px"><i class="bi bi-graph-down-arrow"></i> @T("Dash.DeviceFailures")</div>
            @if (_failures.Count == 0)
            {
                <p class="subtle" style="margin:0">@T("Dash.NoFailures")</p>
            }
            else
            {
                var maxF = Math.Max(_failures.Max(f => f.FailureCount), 1);
                @foreach (var f in _failures.OrderByDescending(x => x.FailureCount).Take(10))
                {
                    <div class="bar-row">
                        <div class="bar-label" title="@f.BrandName @f.ModelName">@f.BrandName @f.ModelName</div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width:@(Math.Max(f.FailureCount * 100.0 / maxF, 6).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%;background:linear-gradient(90deg,#ef4444,#f97316)">@f.FailureCount</div>
                        </div>
                        <div class="subtle" style="width:180px;flex-shrink:0">
                            @(f.MostCommonCategory ?? "—") · @T("Dash.Repeat", f.RepeatCustomersCount)
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private DashboardSummaryDto? _summary;
    private Dictionary<string, int> _byStatus = [];
    private List<HourlyCallVolumeDto> _calls = [];
    private List<AgentPerformanceDto> _agents = [];
    private List<DeviceFailureReportDto> _failures = [];

    private DateTime _date = DateTime.UtcNow.Date;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
        {
            _date = d.Date;
            await RefreshAsync();
        }
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();
        try
        {
            var from = DateTime.UtcNow.Date.AddDays(-30);

            // Sequential-friendly: fire all, then await (WASM is single-threaded but requests overlap).
            var summaryTask = Api.GetDashboardSummaryAsync(_date);
            var statusTask = Api.GetTicketsByStatusAsync();
            var callsTask = Api.GetCallVolumeAsync(_date);
            var agentsTask = Api.GetAgentPerformanceAsync(from, DateTime.UtcNow);
            var failuresTask = Api.GetDeviceFailuresAsync(from, DateTime.UtcNow);

            _summary = await summaryTask;
            _byStatus = await statusTask;
            _calls = await callsTask;
            _agents = await agentsTask;
            _failures = await failuresTask;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            if (_summary is null) Toasts.Error(ex.Message);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string SlaBadge(double rate) =>
        rate >= 90 ? "badge-green" : rate >= 70 ? "badge-amber" : "badge-red";
}
