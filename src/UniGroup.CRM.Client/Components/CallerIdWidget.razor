@inherits LocalizedComponentBase
@inject CallerIdService CallerId
@inject CrmApiClient Api
@inject ToastService Toasts
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Floating Caller-ID simulator — bottom-right corner utility *@

<button class="caller-fab @(CallerId.IsRinging ? "ringing" : "")" title="@T("Caller.SimTitle")" @onclick="TogglePanel">
    <span class="ico"><i class="bi @(CallerId.IsRinging ? "bi-phone-vibrate" : CallerId.IsInCall ? "bi-headset" : "bi-telephone")"></i></span>
</button>

@if (_panelOpen)
{
    <div class="glass caller-panel anim-fade-up">
        @if (CallerId.IsRinging)
        {
            @* ------- Incoming call (ringing) ------- *@
            <div class="caller-incoming">
                <div class="subtle" style="letter-spacing:0.12em;text-transform:uppercase">@T("Caller.Incoming")</div>
                <div class="phone-num mono">@CallerId.IncomingNumber</div>

                @if (CallerId.Caller is not null)
                {
                    <div class="row" style="justify-content:center;margin-top:8px">
                        <div class="avatar lg">@UiHelpers.Initials(CallerId.Caller.Name)</div>
                        <div style="text-align:start">
                            <div style="font-weight:700;font-size:15px">@CallerId.Caller.Name</div>
                            <div class="subtle">@(CallerId.Caller.City ?? "—") · @T("Common.DevicesCount", CallerId.Caller.Devices.Count)</div>
                        </div>
                    </div>
                    @if (CallerId.Caller.Devices.Any(d => d.WarrantyStatus == "Active"))
                    {
                        <span class="badge badge-green" style="margin-top:8px"><span class="dot"></span> @T("Caller.ActiveWarrantyOnFile")</span>
                    }
                }
                else
                {
                    <span class="badge badge-amber" style="margin-top:8px"><i class="bi bi-exclamation-triangle"></i> @T("Caller.Unknown")</span>
                }

                <div class="call-actions">
                    <button class="call-btn answer" title="@T("Caller.Answer")" @onclick="Answer"><i class="bi bi-telephone-fill"></i></button>
                    <button class="call-btn decline" title="@T("Caller.Decline")" @onclick="Decline"><i class="bi bi-telephone-x-fill"></i></button>
                </div>
            </div>
        }
        else if (CallerId.IsInCall)
        {
            @* ------- Active call ------- *@
            <div class="spread" style="margin-bottom:12px">
                <div class="section-title"><span style="color:var(--success)">●</span> @T("Caller.OnCall") · <span class="mono">@_callDuration</span></div>
                <span class="badge badge-green mono">@CallerId.IncomingNumber</span>
            </div>

            @if (CallerId.Caller is not null)
            {
                <div class="row" style="margin-bottom:12px">
                    <div class="avatar">@UiHelpers.Initials(CallerId.Caller.Name)</div>
                    <div style="min-width:0;flex:1">
                        <div style="font-weight:700">@CallerId.Caller.Name</div>
                        <div class="subtle">@CallerId.Caller.Email</div>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="OpenProfile">@T("Caller.Open360")</button>
                </div>
            }
            else
            {
                <div class="card" style="padding:12px;margin-bottom:12px">
                    <div class="subtle" style="margin-bottom:8px">@T("Caller.UnknownCreate")</div>
                    <div class="field" style="margin-bottom:8px">
                        <input class="input" @bind="_newCustomerName" @bind:event="oninput" placeholder="@T("Caller.CustomerName")" />
                    </div>
                    <button class="btn btn-secondary btn-sm" style="width:100%" @onclick="QuickCreateAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newCustomerName))">
                        @if (_busy)
                        {
                            @T("TkC.Creating")
                        }
                        else
                        {
                            <i class="bi bi-plus-lg"></i> @T("Caller.QuickCreate")
                        }
                    </button>
                </div>
            }

            <div class="row" style="gap:10px;align-items:flex-start">
                <div class="field" style="flex:1">
                    <label>@T("TkC.MainCategory")</label>
                    <select class="select" @onchange="OnCallMainCategoryChanged">
                        <option value="" selected="@(_callMainCategory is null)">@T("Caller.NoClassification")</option>
                        @foreach (var mc in Enum.GetValues<MainCategory>())
                        {
                            <option value="@((int)mc)" selected="@(_callMainCategory == mc)">@TMainCategory(mc.ToString())</option>
                        }
                    </select>
                </div>
                <div class="field" style="flex:1">
                    <label>@T("TkC.SubCategory")</label>
                    <select class="select" @onchange="OnCallSubCategoryChanged" disabled="@(_callMainCategory is null)">
                        <option value="" selected="@(_callSubCategory is null)">@T("Caller.NoClassification")</option>
                        @if (_callMainCategory is not null)
                        {
                            @foreach (var cat in TicketCategoryMap.GetSubCategories(_callMainCategory.Value))
                            {
                                <option value="@((int)cat)" selected="@(_callSubCategory == cat)">@TCategory(cat.ToString())</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="field">
                <label>@T("Caller.CallSummary")</label>
                <textarea class="textarea" style="min-height:64px" @bind="_summary" @bind:event="oninput" placeholder="@T("Caller.SummaryPlaceholder")"></textarea>
            </div>
            <button class="btn btn-danger" style="width:100%" @onclick="EndCallAsync" disabled="@_busy">
                <i class="bi bi-stop-fill"></i> @T("Caller.EndAndLog")
            </button>
        }
        else
        {
            @* ------- Simulator idle: dial pad ------- *@
            <div class="section-title" style="margin-bottom:4px"><i class="bi bi-telephone"></i> @T("Caller.SimTitle")</div>
            <p class="subtle" style="margin:0 0 12px">@T("Caller.SimDesc")</p>
            <div class="field" style="margin-bottom:10px">
                <label>@T("Caller.PhoneNumber")</label>
                <input class="input mono" @bind="_dialNumber" @bind:event="oninput" placeholder="@T("Caller.PhonePlaceholder")" @onkeydown="OnDialKeyDown" />
            </div>
            <button class="btn btn-primary" style="width:100%" @onclick="SimulateAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_dialNumber))">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>@T("Caller.LookingUp")</span>
                }
                else
                {
                    <span><i class="bi bi-phone-vibrate"></i> @T("Caller.Simulate")</span>
                }
            </button>
        }
    </div>
}

@code {
    private bool _panelOpen;
    private bool _busy;
    private string _dialNumber = string.Empty;
    private string _summary = string.Empty;
    private string _newCustomerName = string.Empty;
    private string _callDuration = "00:00";
    private Timer? _durationTimer;

    // Optional call classification (Task 4).
    private MainCategory? _callMainCategory;
    private TicketCategory? _callSubCategory;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        CallerId.OnChange += OnCallStateChanged;
    }

    private void OnCallStateChanged()
    {
        if (CallerId.IsInCall && _durationTimer is null)
        {
            _durationTimer = new Timer(_ =>
            {
                if (CallerId.AnsweredAtUtc is { } start)
                {
                    var elapsed = DateTime.UtcNow - start;
                    _callDuration = $"{(int)elapsed.TotalMinutes:00}:{elapsed.Seconds:00}";
                    InvokeAsync(StateHasChanged);
                }
            }, null, 1000, 1000);
        }
        else if (!CallerId.IsInCall)
        {
            _durationTimer?.Dispose();
            _durationTimer = null;
            _callDuration = "00:00";
        }

        InvokeAsync(StateHasChanged);
    }

    private void TogglePanel() => _panelOpen = !_panelOpen;

    private async Task OnDialKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_dialNumber))
        {
            await SimulateAsync();
        }
    }

    private async Task SimulateAsync()
    {
        _busy = true;
        try
        {
            var caller = await Api.GetCallerProfileAsync(_dialNumber.Trim());
            CallerId.Ring(_dialNumber.Trim(), caller);
            await JS.InvokeVoidAsync("unigroup.playRingtone");
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message);
        }
        catch (HttpRequestException)
        {
            Toasts.Error(T("Common.CannotReachApi"));
        }
        finally
        {
            _busy = false;
        }
    }

    private void OpenProfile()
    {
        if (CallerId.Caller is not null)
        {
            _panelOpen = false;
            Nav.NavigateTo($"/customers/{CallerId.Caller.Id}");
        }
    }

    private void Answer()
    {
        CallerId.Answer();
        // Instantly open the customer's 360° profile for known callers.
        if (CallerId.Caller is not null)
        {
            Nav.NavigateTo($"/customers/{CallerId.Caller.Id}");
        }
    }

    private async Task Decline()
    {
        // Log the declined (missed) call with zero duration.
        await LogCallAsync(0, T("Caller.DeclinedNote"));
        CallerId.End();
    }

    private async Task QuickCreateAsync()
    {
        _busy = true;
        try
        {
            var id = await Api.CreateCustomerAsync(new CreateCustomerRequest(
                _newCustomerName.Trim(), null, null, null, null, CallerId.IncomingNumber!));
            var customer = await Api.GetCustomerAsync(id);
            CallerId.Ring(CallerId.IncomingNumber!, customer); // refresh caller info
            CallerId.Answer();
            Toasts.Success(T("Caller.CustomerCreated", customer.Name));
            Nav.NavigateTo($"/customers/{id}");
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    // ───── call classification (cascading) ─────
    private void OnCallMainCategoryChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _callMainCategory = (MainCategory)v;

            // Keep the sub-category consistent with the newly chosen main category.
            if (_callSubCategory is not null &&
                !TicketCategoryMap.GetSubCategories(_callMainCategory.Value).Contains(_callSubCategory.Value))
            {
                _callSubCategory = null;
            }
        }
        else
        {
            _callMainCategory = null;
            _callSubCategory = null;
        }
    }

    private void OnCallSubCategoryChanged(ChangeEventArgs e)
    {
        _callSubCategory = int.TryParse(e.Value?.ToString(), out var v)
            ? (TicketCategory)v
            : null;
    }

    private async Task EndCallAsync()
    {
        var duration = CallerId.AnsweredAtUtc is { } start
            ? (int)(DateTime.UtcNow - start).TotalSeconds
            : 0;
        await LogCallAsync(duration, string.IsNullOrWhiteSpace(_summary) ? null : _summary.Trim());
        _summary = string.Empty;
        _newCustomerName = string.Empty;
        _callMainCategory = null;
        _callSubCategory = null;
        CallerId.End();
    }

    private async Task LogCallAsync(int durationSeconds, string? summary)
    {
        _busy = true;
        try
        {
            await Api.LogCallAsync(new LogCallRequest(
                CallerId.Caller?.Id,
                "Inbound",
                CallerId.IncomingNumber ?? _dialNumber,
                durationSeconds,
                summary,
                null,
                _callMainCategory,
                _callSubCategory));
            Toasts.Success(T("Caller.CallLogged"));
        }
        catch (ApiException ex)
        {
            Toasts.Error(T("Caller.LogFailed", ex.Message));
        }
        catch (HttpRequestException)
        {
            Toasts.Error(T("Common.CannotReachApi"));
        }
        finally
        {
            _busy = false;
        }
    }

    public override void Dispose()
    {
        base.Dispose();
        CallerId.OnChange -= OnCallStateChanged;
        _durationTimer?.Dispose();
    }
}
